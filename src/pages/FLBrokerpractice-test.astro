<script is:inline src="/FLBrokerpracticetest2.js"></script>

<script is:inline>
    function initApp() {
        console.log("Checking for question bank...");
        
        // Wait a split second to ensure the big file is parsed
        if (!window.questionBanks) {
            return setTimeout(initApp, 100);
        }

        let total = 0;
        for (let key in window.questionBanks) {
            total += window.questionBanks[key].length;
        }
        
        const totalEl = document.getElementById('total-questions-header');
        if (totalEl) totalEl.innerText = total;
        console.log("Success! Loaded questions:", total);

        // Start Timer
        let seconds = 0;
        setInterval(() => {
            seconds++;
            const mins = Math.floor(seconds / 60).toString().padStart(2, '0');
            const secs = (seconds % 60).toString().padStart(2, '0');
            const timerEl = document.getElementById('timer');
            if (timerEl) timerEl.innerText = mins + ":" + secs;
        }, 1000);
    }

    // Define the button logic globally
    window.startQuiz = function(examId) {
        const bank = window.questionBanks[examId];
        if (!bank) return alert("Exam " + examId + " not found!");
        
        window.currentQuestions = [...bank];
        window.currentIdx = 0;
        window.score = 0;

        document.getElementById('home-screen').classList.add('hidden');
        document.getElementById('quiz-screen').classList.remove('hidden');
        showQuestion();
    };

    // Run the initialization
    initApp();
</script>