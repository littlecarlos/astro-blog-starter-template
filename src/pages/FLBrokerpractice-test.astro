        exam7: [
    { question: "The IRS allows homeowners to exclude capital gains from the sale of their principal residence if they meet ownership and use tests. What is the maximum exclusion for a married couple filing jointly?", options: ["$125,000", "$250,000", "$500,000", "Unlimited"], answer: 2, explanation: "Married couples may exclude up to $500,000; single filers up to $250,000." },
    { question: "To qualify for the capital gains exclusion on a primary residence, the owner must have lived in the property for:", options: ["1 of the last 2 years", "2 of the last 5 years", "5 consecutive years", "At least 10 years"], answer: 1, explanation: "Owners must occupy the property as their primary residence for 2 of the previous 5 years." },
    { question: "Which expense is deductible for homeowners?", options: ["Principal payments", "Mortgage interest", "Homeowner’s insurance", "HOA dues"], answer: 1, explanation: "Mortgage interest on a primary residence is tax deductible." },
    { question: "Which property is eligible for a 1031 exchange?", options: ["Personal residence", "Vacation home not rented", "Investment real estate", "Personal automobile"], answer: 2, explanation: "1031 exchanges apply to investment or business-use real estate only." },
    { question: "Depreciation for residential income property is taken over:", options: ["15 years", "27.5 years", "30 years", "39 years"], answer: 1, explanation: "Residential rental property is depreciated over 27.5 years." },
    { question: "Depreciation for commercial income property is taken over:", options: ["27.5 years", "30 years", "39 years", "40 years"], answer: 2, explanation: "Commercial real estate is depreciated over 39 years." },
    { question: "Which tax benefit is available to homeowners but not to renters?", options: ["Deduction for mortgage interest and property taxes", "Deduction for utilities", "Deduction for insurance premiums", "Deduction for repairs"], answer: 0, explanation: "Renters cannot deduct interest or property taxes." },
    { question: "The adjusted basis of a property is calculated as:", options: ["Purchase price – mortgage balance", "Purchase price + improvements – depreciation", "Appraised value – loan payoff", "Market value – tax credits"], answer: 1, explanation: "Adjusted basis = original cost + capital improvements – depreciation." },
    { question: "A homeowner sells their primary residence after living there for only one year due to a job transfer. Can they claim a capital gains exclusion?", options: ["No, they do not qualify", "Yes, full exclusion", "Yes, partial exclusion for hardship", "Only if married"], answer: 2, explanation: "IRS allows prorated exclusions for certain hardships (job transfer, health reasons)." },
    { question: "Points paid by a borrower on a mortgage loan are:", options: ["Not deductible", "Deductible in the year paid if for primary residence", "Deductible over the life of the loan only", "Deductible only if refinanced"], answer: 1, explanation: "Points paid on purchase of a primary residence are deductible in the year paid." },
    { question: "Which of the following is considered a capital improvement?", options: ["Repainting the house", "Replacing a roof", "Mowing the lawn", "Pest control"], answer: 1, explanation: "Capital improvements add value or extend life; maintenance (painting, mowing) does not." },
    { question: "A homeowner pays $6,000 in property taxes this year. How much is deductible on their federal income tax return?", options: ["$6,000", "$5,000", "$10,000", "Limited by $10,000 SALT cap"], answer: 3, explanation: "State and local tax (SALT) deductions are capped at $10,000 (includes property tax)." },
    { question: "Which of the following is NOT deductible as an operating expense on rental property?", options: ["Management fees", "Depreciation", "Property improvements", "Property insurance"], answer: 2, explanation: "Improvements must be capitalized and depreciated, not expensed immediately." },
    { question: "When a property is inherited, the basis for heirs is:", options: ["Original purchase price", "Original cost plus improvements", "Fair market value at time of death", "Adjusted basis of deceased owner"], answer: 2, explanation: "Inherited property receives a “stepped-up basis” to current market value." },
    { question: "Which tax applies to income earned from investment real estate?", options: ["Capital gains tax", "Excise tax", "Transfer tax", "Gift tax"], answer: 0, explanation: "Profits from investment real estate are subject to capital gains tax." },
    { question: "Which tax form reports rental income and expenses?", options: ["Schedule A", "Schedule E", "Schedule D", "Form 1099"], answer: 1, explanation: "Rental income and expenses are reported on IRS Schedule E." },
    { question: "Which of the following is considered taxable boot in a 1031 exchange?", options: ["Like-kind real estate", "Mortgage balance transferred", "Cash received in the exchange", "Depreciation recapture"], answer: 2, explanation: "“Boot” is any non-like-kind property or cash received." },
    { question: "The IRS requires depreciation recapture at what tax rate (for residential real estate)?", options: ["10%", "15%", "20%", "25%"], answer: 3, explanation: "Depreciation recapture is taxed at a maximum rate of 25%." },
    { question: "What is the purpose of a 1031 like-kind exchange?", options: ["To avoid capital gains taxes permanently", "To defer capital gains taxes", "To increase depreciation benefits", "To eliminate depreciation recapture"], answer: 1, explanation: "1031 exchanges defer, not eliminate, capital gains taxes." },
    { question: "A married couple filing jointly sells their primary residence with $650,000 in gain. How much is taxable?", options: ["$0", "$150,000", "$400,000", "$650,000"], answer: 1, explanation: "Exclusion is $500,000; $150,000 is taxable gain." },
    { question: "The main advantage of real estate as an investment is:", options: ["High liquidity", "Tax benefits and leverage", "Low transaction costs", "Guaranteed appreciation"], answer: 1, explanation: "Real estate offers leverage, depreciation, and tax advantages, but is not liquid." },
    { question: "Liquidity in real estate refers to:", options: ["Ability to sell quickly for cash", "Ability to refinance", "Ability to raise rents", "Ability to depreciate"], answer: 0, explanation: "Real estate is generally illiquid compared to stocks or bonds." },
    { question: "Cash flow is calculated as:", options: ["Net operating income – debt service", "Gross income – vacancy", "NOI ÷ property value", "Gross income – taxes only"], answer: 0, explanation: "Cash flow is NOI minus debt service (mortgage payments)." },
    { question: "The rate of return that equates the present value of cash inflows with outflows is:", options: ["Capitalization rate", "Internal rate of return (IRR)", "Net present value (NPV)", "Gross rent multiplier"], answer: 1, explanation: "IRR is the yield rate making inflows = outflows." },
    { question: "The capitalization rate (Cap Rate) is found by:", options: ["NOI ÷ Value", "Value ÷ NOI", "NOI × Loan amount", "Value ÷ Gross income"], answer: 0, explanation: "Cap rate = NOI ÷ Value." },
    { question: "An investor’s equity is equal to:", options: ["Property value – mortgage balance", "Cash invested + appreciation", "Loan balance + expenses", "NOI × cap rate"], answer: 0, explanation: "Equity = market value minus debt owed." },
    { question: "Which risk refers to changes in interest rates affecting investment value?", options: ["Business risk", "Purchasing power risk", "Financial risk", "Interest rate risk"], answer: 3, explanation: "Interest rate risk affects borrowing costs and investor yields." },
    { question: "Operating expenses include all of the following EXCEPT:", options: ["Property taxes", "Maintenance costs", "Loan payments", "Insurance"], answer: 2, explanation: "Debt service (loan payments) is not an operating expense." },
    { question: "Which analysis measures how long it will take to recover the investment?", options: ["Cash-on-cash return", "Payback period", "Net present value", "Internal rate of return"], answer: 1, explanation: "Payback period = time required to recoup investment." },
    { question: "The benefit of leverage in real estate is:", options: ["Increases liquidity", "Magnifies returns using borrowed funds", "Eliminates risk", "Increases depreciation"], answer: 1, explanation: "Leverage uses borrowed money to control larger investments, magnifying gains (or losses)." },
    { question: "An investment that produces steady income with low risk is considered:", options: ["Speculative", "Safe", "Risky", "Illiquid"], answer: 1, explanation: "Safe investments generate stable income with low volatility." },
    { question: "Positive leverage occurs when:", options: ["Cost of borrowing is less than the return on investment", "Cost of borrowing is higher than returns", "Equity decreases", "Property is fully depreciated"], answer: 0, explanation: "Positive leverage magnifies returns if loan interest is below ROI." },
    { question: "Which ratio compares before-tax cash flow to cash invested?", options: ["Debt coverage ratio", "Cash-on-cash return", "Cap rate", "Break-even ratio"], answer: 1, explanation: "Cash-on-cash = Before-tax cash flow ÷ Cash invested." },
    { question: "Break-even ratio measures:", options: ["Loan payments ÷ NOI", "Operating expenses + debt service ÷ Gross income", "NOI ÷ Loan balance", "Cash flow ÷ Equity"], answer: 1, explanation: "Break-even ratio shows how much income is required to cover expenses and debt." },
    { question: "Which factor is NOT considered in the time value of money?", options: ["Present value", "Future value", "Discount rate", "Gross rent multiplier"], answer: 3, explanation: "GRM is a shortcut valuation, not part of TVM." },
    { question: "Net present value (NPV) is positive when:", options: ["The discount rate is lower than IRR", "The present value of inflows exceeds outflows", "The cap rate is greater than market value", "Expenses exceed income"], answer: 1, explanation: "Positive NPV means the investment adds value." },
    { question: "Which investment vehicle pools money from investors to purchase real estate?", options: ["Syndication", "1031 Exchange", "REIT (Real Estate Investment Trust)", "Sale-leaseback"], answer: 2, explanation: "REITs allow investors to buy shares in real estate portfolios." },
    { question: "Business risk in real estate investment refers to:", options: ["The economy", "Vacancies and management issues", "Interest rate changes", "Inflation"], answer: 1, explanation: "Business risk comes from tenants, occupancy, and operations." },
    { question: "A sale-leaseback arrangement benefits the seller because:", options: ["It eliminates depreciation", "It provides liquidity while retaining use", "It increases equity", "It eliminates tax liability"], answer: 1, explanation: "Seller frees up capital by selling property but leases it back for continued use." },
    { question: "Which investment measure is most commonly used to value income-producing property?", options: ["Gross rent multiplier", "Break-even ratio", "Capitalization rate", "Equity dividend ratio"], answer: 2, explanation: "Cap rate is widely used to compare and value income-producing properties." },
    { question: "Zoning laws are an example of:", options: ["Private restrictions", "Police power", "Eminent domain", "Escheat"], answer: 1, explanation: "Zoning is an exercise of the government’s police power to protect public health, safety, and welfare." },
    { question: "A nonconforming use is:", options: ["A violation of zoning", "A use that was legal before new zoning was adopted", "A conditional use permit", "A variance"], answer: 1, explanation: "Nonconforming use is grandfathered in because it existed lawfully before zoning changes." },
    { question: "A variance allows a property owner to:", options: ["Bypass all zoning rules", "Continue a nonconforming use indefinitely", "Make a minor deviation from zoning requirements", "Change zoning classification"], answer: 2, explanation: "A variance is granted for minor deviations (e.g., setback requirements)." },
    { question: "Which land-use control takes precedence over local zoning?", options: ["Private deed restriction", "HOA covenant", "Federal environmental regulation", "Municipal zoning ordinance"], answer: 2, explanation: "Federal and state environmental laws supersede local zoning." },
    { question: "A conditional use permit allows:", options: ["Any use chosen by the owner", "A use benefiting the public, even if not zoned for it", "A change in zoning classification", "An unlawful use to continue"], answer: 1, explanation: "Conditional use permits allow uses like schools or churches in residential areas." },
    { question: "Eminent domain is the power of:", options: ["The owner to sell at will", "Government to take property for public use with compensation", "Court to void contracts", "Brokers to force sales"], answer: 1, explanation: "Eminent domain allows government to acquire property for public use with just compensation." },
    { question: "The process of taking property through eminent domain is called:", options: ["Seizin", "Escheat", "Condemnation", "Adverse possession"], answer: 2, explanation: "Condemnation is the legal process to exercise eminent domain." },
    { question: "What is spot zoning?", options: ["Zoning a small area differently from surrounding property", "Rezoning farmland for development", "Applying conditional use", "Illegal discrimination in zoning"], answer: 0, explanation: "Spot zoning benefits one parcel differently from nearby areas." },
    { question: "The purpose of a comprehensive plan is to:", options: ["Encourage private deed restrictions", "Control state taxation", "Guide long-term land use development", "Guarantee property values"], answer: 2, explanation: "Comprehensive plans provide long-term growth and land-use guidelines." },
    { question: "Which agency enforces Florida’s Growth Policy?", options: ["HUD", "Department of Business and Professional Regulation", "Department of Economic Opportunity", "FREC"], answer: 2, explanation: "The Florida Department of Economic Opportunity oversees growth management and planning." },
    { question: "Building codes are primarily concerned with:", options: ["Aesthetic appearance", "Safety and construction standards", "Market value", "Zoning classifications"], answer: 1, explanation: "Building codes regulate safety, materials, and construction methods." },
    { question: "What is downzoning?", options: ["Rezoning from residential to commercial", "Rezoning to a more restrictive classification", "Granting a variance", "Reducing lot size requirements"], answer: 1, explanation: "Downzoning restricts property use, often reducing density." },
    { question: "Which legal doctrine allows local governments to regulate private land use for the health, safety, and welfare of the community?", options: ["Eminent domain", "Police power", "Escheat", "Adverse possession"], answer: 1, explanation: "Police power authorizes zoning and building regulations." },
    { question: "An owner wants to build closer to the property line than zoning allows. They must apply for a:", options: ["Variance", "Special use permit", "Rezoning", "Nonconforming use permit"], answer: 0, explanation: "A variance permits deviation from zoning requirements." },
    { question: "Which of the following would terminate a nonconforming use?", options: ["Sale of the property", "Change in zoning", "Destruction of the structure", "Issuance of variance"], answer: 2, explanation: "If the building is destroyed, the nonconforming use typically ends." },
    { question: "Escheat occurs when:", options: ["Property is condemned", "An owner dies without a will or heirs", "Taxes are unpaid", "Government takes for public use"], answer: 1, explanation: "Property reverts to the state if an owner dies intestate with no heirs." },
    { question: "Which of the following is a private land-use control?", options: ["Zoning ordinance", "Building codes", "Deed restrictions (restrictive covenants)", "Comprehensive plan"], answer: 2, explanation: "Deed restrictions are private limitations imposed by the seller or HOA." },
    { question: "Which government action most affects property value?", options: ["Issuing mortgage loans", "Establishing zoning and land use regulations", "Conducting appraisals", "Enforcing leases"], answer: 1, explanation: "Zoning has major influence on property values." },
    { question: "A buffer zone is used to:", options: ["Prevent eminent domain", "Separate incompatible land uses", "Increase density in residential areas", "Protect against environmental hazards"], answer: 1, explanation: "Buffer zones transition between different land uses (e.g., commercial to residential)." },
    { question: "Which of the following is a legal taking of private property for public use?", options: ["Police power", "Eminent domain", "Escheat", "Foreclosure"], answer: 1, explanation: "Eminent domain allows the government to take property with compensation." },
    { question: "Which federal law requires disclosure of lead-based paint in residential properties built before 1978?", options: ["CERCLA", "RCRA", "Lead-Based Paint Hazard Reduction Act", "Clean Water Act"], answer: 2, explanation: "The Lead-Based Paint Hazard Reduction Act requires disclosure in homes built before 1978." },
    { question: "Which environmental hazard is naturally occurring and found in Florida’s limestone and granite?", options: ["Lead", "Radon gas", "Asbestos", "Carbon monoxide"], answer: 1, explanation: "Radon gas is a naturally occurring radioactive gas in Florida soils." },
    { question: "What type of asbestos is most dangerous?", options: ["Encapsulated", "Friable", "Non-friable", "Synthetic"], answer: 1, explanation: "Friable asbestos can crumble easily, releasing fibers into the air." },
    { question: "CERCLA is also known as the:", options: ["Superfund Act", "Safe Drinking Water Act", "Clean Air Act", "Wetlands Protection Act"], answer: 0, explanation: "CERCLA (Comprehensive Environmental Response, Compensation, and Liability Act) is called the Superfund Act." },
    { question: "The Florida Radon Disclosure requires:", options: ["Radon testing for all sales", "Sellers to disclose the possible presence of radon gas", "Brokers to pay for radon inspections", "Radon remediation prior to closing"], answer: 1, explanation: "Florida requires a disclosure that radon may be present, not mandatory testing." },
    { question: "Mold is primarily a concern because it:", options: ["Creates a structural hazard", "Causes health problems and property damage", "Reduces property taxes", "Cannot be remediated"], answer: 1, explanation: "Mold affects air quality, causes illness, and damages structures." },
    { question: "Brownfields are defined as:", options: ["Areas of agricultural land", "Abandoned or underused industrial sites with contamination", "Protected wetlands", "Residential subdivisions"], answer: 1, explanation: "Brownfields are contaminated or potentially contaminated former industrial sites." },
    { question: "The Clean Water Act regulates:", options: ["Lead paint", "Wetlands and water pollution", "Asbestos removal", "Hazardous waste disposal"], answer: 1, explanation: "The Clean Water Act regulates pollution into U.S. waters and protects wetlands." },
    { question: "The environmental site assessment most lenders require before financing commercial property is called a:", options: ["Phase I Environmental Site Assessment", "Phase II Assessment", "Radon Report", "CERCLA Review"], answer: 0, explanation: "Phase I ESA identifies potential contamination; Phase II involves testing if needed." },
    { question: "Which law regulates underground storage tanks?", options: ["RCRA (Resource Conservation and Recovery Act)", "CERCLA", "Clean Air Act", "Superfund Amendments"], answer: 0, explanation: "RCRA governs hazardous waste handling and underground storage tanks." },
    { question: "The presence of wetlands on property can:", options: ["Increase property value", "Restrict development and land use", "Automatically cancel sales contracts", "Require radon testing"], answer: 1, explanation: "Wetlands are protected and restrict how property may be developed." },
    { question: "Which gas is odorless, colorless, and can cause death due to poor ventilation?", options: ["Carbon monoxide", "Radon", "Methane", "Asbestos"], answer: 0, explanation: "Carbon monoxide is a deadly gas caused by incomplete combustion." },
    { question: "What is the main risk of underground storage tanks (USTs)?", options: ["Fire hazard", "Contamination of groundwater", "Air pollution", "Asbestos release"], answer: 1, explanation: "Leaking USTs can contaminate soil and groundwater." },
    { question: "Which environmental law holds current and past owners liable for cleanup of hazardous waste?", options: ["Clean Air Act", "CERCLA (Superfund)", "RCRA", "Safe Water Act"], answer: 1, explanation: "CERCLA imposes strict liability on owners, even if they didn’t cause contamination." },
    { question: "Environmental impact statements (EIS) are required for:", options: ["All property sales", "Federally funded projects affecting the environment", "Local zoning changes", "Private land transfers"], answer: 1, explanation: "EIS are required for major projects involving federal funds." },
    { question: "Which of the following environmental hazards is most commonly found in older insulation and building materials?", options: ["Lead", "Radon", "Asbestos", "Mold"], answer: 2, explanation: "Asbestos was widely used in insulation and flooring materials." },
    { question: "Which type of property is most likely to require a Phase II Environmental Assessment?", options: ["Vacant residential lot", "Former gas station", "New construction home", "Farmland with crops"], answer: 1, explanation: "Gas stations are high risk for soil contamination from leaking tanks." },
    { question: "Who is responsible for providing the lead-based paint disclosure in a sale?", options: ["Buyer", "Seller and their agent", "Lender", "Closing agent"], answer: 1, explanation: "Sellers and their agents must provide the lead disclosure form." },
    { question: "Which law requires safe disposal of hazardous waste from “cradle to grave”?", options: ["CERCLA", "Clean Air Act", "RCRA", "NEPA"], answer: 2, explanation: "RCRA regulates hazardous waste from creation to disposal." },
    { question: "A subdivision located near a factory emitting pollutants may suffer from:", options: ["Functional obsolescence", "Economic (external) obsolescence", "Physical deterioration", "Voluntary conformity"], answer: 1, explanation: "External obsolescence is loss in value due to outside environmental factors." },
    { question: "The primary responsibility of a property manager is to:", options: ["Maximize tenant satisfaction", "Maximize the owner’s return on investment", "Increase government regulation", "Sell the property quickly"], answer: 1, explanation: "A property manager’s fiduciary duty is to the owner — to protect and maximize their investment." },
    { question: "A management agreement is between:", options: ["Broker and tenant", "Owner and property manager", "Tenant and HOA", "Broker and city government"], answer: 1, explanation: "The management contract establishes the relationship between owner and manager." },
    { question: "A typical property manager’s compensation is based on:", options: ["A percentage of gross rental income", "A percentage of net income", "Property value", "Number of tenants"], answer: 0, explanation: "Most managers earn a percentage of collected gross rent." },
    { question: "Which type of maintenance is done to prevent problems before they occur?", options: ["Corrective maintenance", "Preventive maintenance", "Deferred maintenance", "Functional maintenance"], answer: 1, explanation: "Preventive maintenance reduces long-term costs and problems." },
    { question: "Which type of insurance protects against employee theft in property management?", options: ["General liability", "Surety bond (fidelity bond)", "Hazard insurance", "Rent loss insurance"], answer: 1, explanation: "Fidelity bonds protect against losses due to dishonest employees." },
    { question: "Which type of lease is commonly used for retail space, where tenants pay rent plus part of operating expenses?", options: ["Gross lease", "Net lease", "Percentage lease", "Ground lease"], answer: 2, explanation: "Percentage leases require rent plus a share of tenant’s sales, common in retail." },
    { question: "Which lease requires the landlord to pay all property expenses?", options: ["Gross lease", "Net lease", "Percentage lease", "Ground lease"], answer: 0, explanation: "In a gross lease, the landlord pays expenses; tenant pays fixed rent." },
    { question: "A ground lease typically involves:", options: ["Short-term occupancy", "Leasing land for long-term development", "Shared maintenance costs", "Commercial percentage rent"], answer: 1, explanation: "Ground leases allow tenant to build on leased land for long periods." },
    { question: "Rent that is indexed to inflation is called:", options: ["Fixed rent", "Step-up rent", "Graduated rent", "Index rent"], answer: 3, explanation: "Index rent adjusts periodically based on an inflation index." },
    { question: "The economic principle of supply and demand affects real estate values by:", options: ["Increasing supply raises prices", "Increasing demand with limited supply raises prices", "Decreasing demand raises prices", "Supply has no effect on value"], answer: 1, explanation: "Values rise when demand exceeds supply." },
    { question: "In real estate, absorption rate measures:", options: ["Speed at which new listings sell", "Number of properties available", "Vacancy rate in apartments", "Rate of depreciation"], answer: 0, explanation: "Absorption rate = pace at which available properties are sold/leased." },
    { question: "The vacancy rate is best described as:", options: ["Percentage of units not rented", "Percentage of units rented", "Number of units available for sale", "Tenant turnover rate"], answer: 0, explanation: "Vacancy rate = unoccupied rental units ÷ total units." },
    { question: "A high vacancy rate typically indicates:", options: ["Strong demand", "Weak demand or oversupply", "Rising rents", "Stable market"], answer: 1, explanation: "High vacancy signals excess supply or weak demand." },
    { question: "Which economic indicator has the greatest impact on demand for housing?", options: ["Property tax rates", "Employment levels", "Vacancy rates", "Number of builders in market"], answer: 1, explanation: "Employment and income levels drive housing demand." },
    { question: "Which type of market occurs when supply exceeds demand?", options: ["Seller’s market", "Buyer’s market", "Equilibrium market", "Inflationary market"], answer: 1, explanation: "Buyer’s markets occur when supply is high and buyers have more negotiating power." },
    { question: "In a seller’s market, prices typically:", options: ["Fall", "Rise", "Stay flat", "Are unaffected"], answer: 1, explanation: "Strong demand and limited supply push prices upward." },
    { question: "Which is the best example of corrective maintenance in property management?", options: ["Routine inspection", "Replacing a broken HVAC system", "Changing air filters", "Landscaping"], answer: 1, explanation: "Corrective maintenance fixes problems after they occur." },
    { question: "The principle of competition suggests that:", options: ["Excess profits attract new development", "No two properties are the same", "Buyers act irrationally", "Overbuilding increases prices"], answer: 0, explanation: "Excess profits in a market attract competition, which eventually reduces profits." },
    { question: "Which report must a property manager regularly provide to the owner?", options: ["Personal financial statement", "Operating budget and income/expense reports", "Appraisal report", "Environmental impact statement"], answer: 1, explanation: "Owners expect regular operating and financial performance reports." },
    { question: "The principle of conformity states that:", options: ["Properties achieve maximum value when similar to others in area", "Older homes lose value next to new homes", "Commercial and residential uses should be mixed", "All properties must have identical improvements"], answer: 0, explanation: "Conformity maintains values by ensuring properties are reasonably similar in use and design." }
],
exam8: [
    { question: "A broker must deposit escrow funds no later than:", options: ["End of the next business day after the associate receives them", "End of the third business day after the associate receives them", "End of the fifth business day after the buyer delivers them", "Immediately upon receipt by the sales associate"], answer: 1, explanation: "The timeline starts when the sales associate receives the funds. The broker must deposit them by the end of the third business day following receipt by the associate. (Source: F.A.C. 61J2-14.009)" },
    { question: "A sales associate must deliver an earnest money deposit to the broker by:", options: ["End of the next business day", "End of the third business day", "Immediately", "Within 48 hours"], answer: 0, explanation: "A sales associate must deliver all deposits to their employing broker no later than the end of the next business day after receipt. (Source: F.A.C. 61J2-14.009)" },
    { question: "Blind advertising occurs when an ad fails to include:", options: ["The property address", "The broker’s registered name", "The listing price", "The sales associate’s name"], answer: 1, explanation: "A blind ad is any real estate advertisement that does not contain the registered or trade name of the brokerage firm. (Source: F.A.C. 61J2-10.025)" },
    { question: "A brokerage office sign must include the trade name, broker’s name, and:", options: ["“Licensed Real Estate Broker”", "“Realtor®”", "The office phone number", "The firm’s license number"], answer: 0, explanation: "The sign must contain the trade name (if any), the name of the broker, and the words 'Licensed Real Estate Broker' or 'Lic. Real Estate Broker'. (Source: F.S. 475.22)" },
    { question: "A branch office registration in Florida is:", options: ["Transferable to a new location", "Good for two years", "Nontransferable; a new registration is required if the office relocates", "Only required if more than 3 associates work there"], answer: 2, explanation: "A branch office registration is issued for a specific location and is not transferable. If the office moves, a new registration must be obtained. (Source: F.S. 475.24)" },
    { question: "A postdated check offered as earnest money may be accepted if the broker:", options: ["Deposits it immediately", "Obtains the seller’s written approval and safeguards it until the date", "Returns it to the buyer", "Gives it to the title company"], answer: 1, explanation: "A broker must obtain the seller's express written approval before accepting a postdated check. Once approved, it must be properly secured until the date on the check. (Source: F.A.C. 61J2-14.008)" },
    { question: "Commingling refers to mixing:", options: ["Personal funds with office rent funds", "Escrow funds with the broker’s personal or business funds", "Tenant deposits with accrued late fees", "Two different escrow deposits in one trust account"], answer: 1, explanation: "Commingling is the illegal act of mixing trust funds (escrow money) with a broker's own personal or business operating funds. (Source: F.S. 475.25(1)(k))" },
    { question: "When there are conflicting demands on escrow, the broker must notify FREC within:", options: ["5 business days", "10 business days", "15 business days", "30 business days"], answer: 2, explanation: "A broker must provide written notification to the Florida Real Estate Commission (FREC) within 15 business days of receiving conflicting demands. (Source: F.A.C. 61J2-14.012)" },
    { question: "After notifying FREC of conflicting demands, the broker must initiate a settlement procedure within:", options: ["5 business days", "30 business days", "45 business days", "60 business days"], answer: 1, explanation: "After notifying the FREC, the broker has 30 business days to institute one of the settlement procedures: mediation, arbitration, litigation, or an escrow disbursement order (EDO). (Source: F.A.C. 61J2-14.012)" },
    { question: "A broker who complies with an EDO and is later sued may receive from the Recovery Fund:", options: ["Punitive damages", "Treble damages", "Reimbursement of court costs and reasonable attorney’s fees", "Lost commissions"], answer: 2, explanation: "If a broker follows an Escrow Disbursement Order (EDO) and is subsequently sued, the Recovery Fund will pay the judgment and also reimburse the broker for reasonable attorney's fees and court costs. (Source: F.S. 475.484)" },
    { question: "Recovery Fund maximums per licensee are:", options: ["$25,000 per transaction; $50,000 aggregate", "$50,000 per transaction; $100,000 aggregate", "$50,000 per transaction; $150,000 aggregate", "$100,000 per transaction; $200,000 aggregate"], answer: 2, explanation: "The maximum payment is $50,000 for a single transaction and a total aggregate of $150,000 for multiple claims against the same licensee. (Source: F.S. 475.484)" },
    { question: "The Florida Statute of Frauds requires a contract for sale of real property to be:", options: ["Notarized", "Witnessed by two people", "In writing and signed by the party to be charged", "Recorded to be enforceable"], answer: 2, explanation: "To be enforceable, a contract for the sale of real estate must be in writing and signed by the party against whom enforcement is sought. (Source: F.S. 725.01)" },
    { question: "The statute of limitations for enforcement of a written real estate contract is:", options: ["3 years", "5 years", "4 years", "7 years"], answer: 1, explanation: "A party has five years to bring a lawsuit for the enforcement of a written contract. (Source: F.S. 95.11)" },
    { question: "The statute of limitations for oral real estate contracts is:", options: ["4 years", "5 years", "2 years", "7 years"], answer: 0, explanation: "A party has four years to bring a lawsuit for the enforcement of an oral (parol) contract. (Source: F.S. 95.11)" },
    { question: "A transaction broker owes all of the following except:", options: ["Limited confidentiality", "Presenting all offers and counteroffers", "Obedience", "Accounting for all funds"], answer: 2, explanation: "Obedience is a fiduciary duty owed only in a single agent relationship. A transaction broker does not owe obedience to either party. (Source: F.S. 475.278)" },
    { question: "Duties in a no brokerage relationship include all except:", options: ["Deal honestly and fairly", "Account for all funds", "Disclose known residential property defects", "Loyalty"], answer: 3, explanation: "Loyalty is a fiduciary duty owed only in a single agent relationship. It is not a duty in a no brokerage relationship. (Source: F.S. 475.278)" },
    { question: "A single agent owes a fiduciary duty of:", options: ["Loyalty", "Confidentiality", "Obedience", "All of the above"], answer: 3, explanation: "Fiduciary duties owed by a single agent to their principal include Loyalty, Obedience, Confidentiality, and Full Disclosure. (Source: F.S. 475.278)" },
    { question: "Dual agency in a residential transaction in Florida is:", options: ["Legal with advanced consent", "Legal if disclosed in writing", "Illegal", "Legal if broker designates two associates"], answer: 2, explanation: "A broker cannot represent both the buyer and the seller as a single agent in the same residential transaction. This is an illegal dual agency. (Source: F.S. 475.278)" },
    { question: "Designated sales associates may be used only in:", options: ["Any residential transaction", "Commercial transactions of any size", "Nonresidential transactions where both parties have ≥ $1 million in assets and consent", "Transactions with institutional buyers only"], answer: 2, explanation: "This specific form of representation is limited to non-residential transactions where the buyer and seller each have assets of $1 million or more and request it. (Source: F.S. 475.2755)" },
    { question: "The FREC is composed of:", options: ["7 members: 4 brokers, 1 sales associate/broker, 2 consumer members", "7 members: 5 licensees (at least 4 brokers) and 2 consumer members", "9 members appointed by the Governor", "5 members, all active brokers"], answer: 1, explanation: "The Florida Real Estate Commission has 7 members: 4 must be licensed brokers for at least 5 years, 1 must be a broker or sales associate licensed for at least 2 years, and 2 are consumer members who have never been licensed. (Source: F.S. 475.02)" },
    { question: "FREC’s quasi-legislative power involves:", options: ["Rule-making", "Investigations", "Disciplining licensees", "Issuing final orders in complaints"], answer: 0, explanation: "Quasi-legislative powers are the powers delegated to the FREC to enact rules and regulations to implement the statutes. (Source: F.S. 475.05)" },
    { question: "FREC’s quasi-judicial power involves:", options: ["Passing statutes", "Granting/denying applications and imposing discipline", "Creating education courses", "Collecting renewal fees"], answer: 1, explanation: "Quasi-judicial powers are the powers of the FREC to grant or deny license applications, and to determine violations and impose penalties. (Source: F.S. 475.25)" },
    { question: "The maximum suspension FREC may impose for a first-time violation is:", options: ["5 years", "10 years", "Indefinite", "2 years"], answer: 1, explanation: "The FREC has the authority to suspend a license for a maximum period of 10 years. Revocation is permanent. (Source: F.S. 475.25)" },
    { question: "The maximum administrative fine per violation by FREC is:", options: ["$2,500", "$5,000", "$10,000", "$1,000"], answer: 1, explanation: "FREC may impose an administrative fine not to exceed $5,000 for each count or separate offense. (Source: F.S. 475.25)" },
    { question: "A license becomes null and void if involuntarily inactive for more than:", options: ["12 months", "24 months", "18 months", "36 months"], answer: 1, explanation: "A license that has been in an involuntarily inactive status for more than two years (24 months) automatically becomes null and void. (Source: F.S. 475.183)" },
    { question: "To reactivate a license involuntarily inactive for 12–24 months, the licensee must complete:", options: ["14 hours CE", "28-hour reactivation course", "45-hour post-license", "72-hour prelicense again"], answer: 1, explanation: "For a license that has been involuntarily inactive for more than 12 but less than 24 months, the licensee must complete a 28-hour reactivation course. (Source: F.A.C. 61J2-3.010)" },
    { question: "A broker’s books and records must be retained for at least:", options: ["3 years", "5 years (and longer if litigation or if part of escrow dispute)", "7 years", "10 years"], answer: 1, explanation: "Brokers must preserve essential records for at least five years. If any record is part of litigation or an investigation, it must be kept for two years after the conclusion of that proceeding. (Source: F.S. 475.5015)" },
    { question: "Which business may NOT register as a real estate brokerage?", options: ["Corporation", "Limited partnership", "Corporation sole", "LLC"], answer: 2, explanation: "A corporation sole is a legal entity for religious organizations and cannot be registered as a real estate brokerage. (Source: F.S. 475.15)" },
    { question: "A general partner in a real estate limited partnership that renders brokerage services must be:", options: ["Unlicensed", "A sales associate", "An active broker", "A broker associate"], answer: 2, explanation: "In a limited partnership brokerage, any general partner who deals with the public and performs brokerage services must be licensed as an active broker. (Source: F.S. 475.15)" },
    { question: "An ostensible partnership (quasi-partnership) exists when:", options: ["Two brokers share commissions", "The public is misled to believe a partnership exists", "A joint venture is formed", "A referral arrangement is created"], answer: 1, explanation: "An ostensible partnership is created by the actions or representations of individuals that lead the public to believe they are partners, even if they are not. This is illegal and can result in license suspension. (Source: F.S. 475.42)" },
    { question: "A sales associate may receive compensation from:", options: ["The buyer’s attorney", "Only the employing broker", "The seller and buyer", "A title company"], answer: 1, explanation: "A sales associate may only accept compensation from their registered employing broker. (Source: F.S. 475.42)" },
    { question: "A sales associate cannot be registered under:", options: ["A broker", "More than one employer at a time", "A developer", "An owner-employer"], answer: 1, explanation: "A sales associate can only have one registered employer at any given time. (Source: F.S. 475.23)" },
    { question: "Paying an unlicensed person a referral fee for a residential sale is:", options: ["Legal up to $100", "Illegal", "Legal with disclosure", "Legal if a tenant referral"], answer: 1, explanation: "It is illegal to share a commission with or pay a fee to an unlicensed person for the referral of real estate business. (Source: F.S. 475.25)" },
    { question: "A property manager may pay a tenant for a referral (within same complex) up to:", options: ["$25", "$50", "$75", "$100"], answer: 1, explanation: "An owner or manager of a residential complex may pay a finder's fee of up to $50 to an unlicensed tenant for the referral of a new tenant. (Source: F.S. 475.011)" },
    { question: "Rental information lists: If the information is not current or accurate, the prospect is entitled to a refund of:", options: ["50% within 30 days", "100% within 30 days", "75% within 30 days", "100% within 10 days"], answer: 1, explanation: "If the information provided in a rental list is not current or is inaccurate, the prospective tenant is entitled to a 100% refund if requested within 30 days. (Source: F.S. 475.453)" },
    { question: "Save Our Homes cap limits annual assessed value increases to:", options: ["5% or CPI", "3% or CPI, whichever is less", "2% fixed", "10%"], answer: 1, explanation: "The Save Our Homes amendment to the Florida Constitution caps the annual increase in the assessed value of a homesteaded property to 3% or the Consumer Price Index (CPI), whichever is less. (Source: Florida Constitution, Art. VII, Sec. 4)" },
    { question: "Portability allows a homesteader to:", options: ["Avoid capital gains", "Transfer some accumulated SOH savings to a new homestead", "Freeze taxes for seniors", "Get a school tax exemption"], answer: 1, explanation: "The portability feature allows homeowners to transfer up to $500,000 of their 'Save Our Homes' assessment difference to a new homestead. (Source: F.S. 193.155)" },
    { question: "Documentary stamp tax on a promissory note in Florida:", options: ["None", "$0.35 per $100 or fraction", "$0.70 per $100", "2 mills"], answer: 1, explanation: "The tax rate for documentary stamps on a promissory note (the loan) is $0.35 per $100 (or fraction thereof) of the face value. (Source: F.S. 201.08)" },
    { question: "Documentary stamp tax on a deed (most Florida counties):", options: ["$0.70 per $100 or fraction", "$0.35 per $100", "$1.00 per $100", "2 mills"], answer: 0, explanation: "The tax rate for documentary stamps on a deed is $0.70 per $100 (or fraction thereof) of the total consideration, except in Miami-Dade County. (Source: F.S. 201.02)" },
    { question: "Intangible tax on new mortgages is:", options: ["$0.70 per $100", "$0.35 per $100", "2 mills (0.002 × new debt)", "None"], answer: 2, explanation: "Florida's intangible personal property tax is levied on new mortgages at a rate of 2 mills, which is equivalent to $0.002 for each dollar of new debt. (Source: F.S. 199.133)" },
    { question: "In Miami-Dade, the deed doc stamp rate for single-family residences is generally:", options: ["$0.60 per $100", "$0.70 per $100", "$0.35 per $100", "2 mills"], answer: 0, explanation: "Miami-Dade County has a surtax. The base rate is $0.60 per $100 for single-family residences, plus the surtax of $0.45 per $100 on transactions over $100,000. For the test, $0.60 is the key base rate to know. (Source: F.S. 201.02, 201.031)" },
    { question: "Florida is a lien theory state, meaning the mortgage:", options: ["Conveys legal title to lender", "Creates a lien; borrower holds title", "Uses a deed of trust", "Conveys both legal and equitable title"], answer: 1, explanation: "In a lien theory state, the mortgage is a lien on the property, and the borrower (mortgagor) retains legal title throughout the loan period. (Source: Florida Property Law)" },
    { question: "A mortgage acceleration clause allows the lender to:", options: ["Lower the rate", "Demand entire balance upon default", "Prevent assumption", "Convert to fixed rate"], answer: 1, explanation: "The acceleration clause gives the lender the right to declare the entire loan balance due and payable immediately upon the borrower's default. (Source: Principles of Real Estate Finance)" },
    { question: "An alienation (due-on-sale) clause:", options: ["Requires property taxes be paid", "Prevents assumption without lender approval", "Guarantees rate changes", "Eliminates PMI"], answer: 1, explanation: "This clause requires the borrower to repay the entire loan balance if the property is sold or transferred, effectively preventing a new buyer from assuming the loan without the lender's consent. (Source: Principles of Real Estate Finance)" },
    { question: "An exculpatory clause in a mortgage:", options: ["Ensures acceleration", "Limits the borrower’s personal liability (nonrecourse)", "Waives escrow", "Requires escrow impounds"], answer: 1, explanation: "An exculpatory clause stipulates that the lender can only look to the property for satisfaction of the debt and cannot obtain a deficiency judgment against the borrower personally. (Source: Principles of Real Estate Finance)" },
    { question: "The index in an ARM:", options: ["Is set by the lender at origination", "Is a market-based benchmark beyond lender’s control", "Equals the margin", "Is the initial teaser rate"], answer: 1, explanation: "The index is a published economic indicator, such as the U.S. Treasury rate, that the lender does not control. The interest rate adjusts based on changes in this index. (Source: Principles of Real Estate Finance)" },
    { question: "The margin in an ARM:", options: ["Is the lender’s spread added to the index", "Changes monthly", "Is always 2%", "Is the cap"], answer: 0, explanation: "The margin is the lender's profit percentage, which is added to the index to determine the fully indexed interest rate. The margin remains constant for the life of the loan. (Source: Principles of Real Estate Finance)" },
    { question: "The cost-depreciation (cost) approach is most applicable to:", options: ["Special-purpose properties", "Existing residential houses in a subdivision", "Income-producing apartments", "Vacant land"], answer: 0, explanation: "The cost approach is most useful for appraising unique, special-purpose properties like schools, churches, or government buildings, for which there are few comparable sales. (Source: Appraisal Principles)" },
    { question: "External obsolescence is a loss in value due to:", options: ["Wear and tear", "Poor floor plan", "Adverse influences outside the property", "Lack of maintenance"], answer: 2, explanation: "External (or economic) obsolescence is a loss in value caused by negative factors outside the property's boundaries, such as a nearby landfill or airport noise. (Source: Appraisal Principles)" },
    { question: "Functional obsolescence example:", options: ["Peeling paint", "Four-bedroom home with one bathroom", "Nearby landfill", "Storm damage"], answer: 1, explanation: "A poor design or outdated feature, such as an inadequate number of bathrooms for the number of bedrooms, is an example of functional obsolescence. (Source: Appraisal Principles)" },
    { question: "GRM is best used for:", options: ["Retail centers", "1–4 unit residential rental properties (monthly rent)", "Office towers", "Hotels"], answer: 1, explanation: "The Gross Rent Multiplier (GRM) is a simplified income approach used for 1-4 unit residential properties, and it is based on the property's monthly rental income. (Source: Appraisal Principles)" },
    { question: "GIM is often applied to:", options: ["Single-family rentals", "Larger income properties using annual income", "Vacant land", "Owner-occupied houses"], answer: 1, explanation: "The Gross Income Multiplier (GIM) is similar to the GRM but is used for larger commercial or industrial properties and is based on annual income. (Source: Appraisal Principles)" },
    { question: "Highest and best use must be:", options: ["Existing use", "Most profitable ignoring zoning", "Legally permissible, physically possible, financially feasible, maximally productive", "Preferred by owner"], answer: 2, explanation: "This is the four-part test for determining a property's highest and best use, a fundamental concept in appraisal. (Source: Appraisal Principles)" },
    { question: "Anticipation principle states value is created by:", options: ["Substitution", "Expected future benefits", "Balance", "Conformity"], answer: 1, explanation: "The principle of anticipation holds that a property's value is based on the present worth of the future benefits (like income or appreciation) it is expected to produce. (Source: Appraisal Principles)" },
    { question: "Progression occurs when:", options: ["A lesser property increases in value due to proximity to superior properties", "A superior property declines due to inferior neighbors", "A property substitutes another", "The market anticipates changes"], answer: 0, explanation: "The principle of progression states that the value of a less expensive home will be pulled up by its association with more expensive homes in the same area. (Source: Appraisal Principles)" },
    { question: "NOI is calculated as:", options: ["PGI − expenses", "EGI − operating expenses", "PGI − debt service", "EGI − reserves − debt service"], answer: 1, explanation: "Net Operating Income (NOI) is found by subtracting all operating expenses from the Effective Gross Income (EGI). Debt service is not an operating expense. (Source: Appraisal Principles)" },
    { question: "Cap rate is:", options: ["NOI ÷ loan amount", "NOI ÷ value (or price)", "Value ÷ NOI", "PGI ÷ price"], answer: 1, explanation: "The basic formula for the capitalization rate is Rate = Net Operating Income / Value (or Sale Price). (Source: Appraisal Principles)" },
    { question: "A property has PGI $240,000, vacancy 5%, expenses $90,000. NOI?", options: ["$120,000", "$138,000", "$150,000", "$100,000"], answer: 1, explanation: "First, find EGI: $240,000 * 5% = $12,000 vacancy loss. $240,000 - $12,000 = $228,000 EGI. Then, find NOI: $228,000 - $90,000 = $138,000. (Source: Appraisal Principles)" },
    { question: "If NOI is $120,000 and market cap rate is 8%, value ≈:", options: ["$1,000,000", "$1,500,000", "$960,000", "$1,200,000"], answer: 1, explanation: "The formula is Value = Income / Rate. $120,000 / 0.08 = $1,500,000. (Source: Appraisal Principles)" },
    { question: "Metes and bounds description uses:", options: ["Lots and blocks", "Rectangular survey", "Monuments, distances, and directions", "Recorded plat only"], answer: 2, explanation: "The metes and bounds method is the oldest form of legal description and relies on monuments, distances (metes), and directions (bounds) to trace the perimeter of a property. (Source: Principles of Land Description)" },
    { question: "In the government survey system, the row immediately south of the baseline is:", options: ["Range 1 South", "Tier 1 South", "Section 1 South", "Township 1 East"], answer: 1, explanation: "Rows of townships running east-west are called tiers. The first tier south of the baseline is Tier 1 South. (Source: Principles of Land Description)" },
    { question: "A tenancy by the entireties may be held by:", options: ["Any two people", "Parent and child", "Legally married couple", "Partners in a firm"], answer: 2, explanation: "This form of ownership, which includes the right of survivorship, is reserved exclusively for married couples in Florida. (Source: Florida Property Law)" },
    { question: "Joint tenancy is characterized by the right of:", options: ["Partition only", "Survivorship", "Curtesy", "Escheat"], answer: 1, explanation: "The primary feature of a joint tenancy is the right of survivorship, meaning a deceased tenant's interest automatically passes to the surviving joint tenants. (Source: Florida Property Law)" },
    { question: "A general warranty deed provides:", options: ["No covenants", "Limited covenants", "The greatest protection to the grantee", "Quitclaim protections"], answer: 2, explanation: "A general warranty deed offers the most comprehensive protection to the buyer (grantee) because it contains all covenants and warranties of title. (Source: Principles of Real Property)" },
    { question: "The habendum clause describes:", options: ["The parties and consideration", "The type of estate being conveyed (“to have and to hold”)", "Property legal description", "Encumbrances"], answer: 1, explanation: "The habendum clause, beginning with 'To have and to hold,' defines the bundle of legal rights being conveyed to the grantee. (Source: Principles of Real Property)" },
    { question: "The granting clause includes:", options: ["Names of grantor and grantee and words of conveyance", "Consideration only", "Reservations", "Habendum language"], answer: 0, explanation: "This clause contains the necessary words of conveyance (e.g., 'grants, bargains, and sells') along with the names of the grantor and grantee. (Source: Principles of Real Property)" },
    { question: "Escheat occurs when:", options: ["A person dies intestate with no heirs; property reverts to the state", "Property is taxed", "Police power is exercised", "Eminent domain is used"], answer: 0, explanation: "Escheat is the government's power to take ownership of property left by a person who died without a will (intestate) and without any legal heirs. (Source: Florida Statutes Chapter 732)" },
    { question: "Eminent domain is the power; the process is called:", options: ["Escheat", "Condemnation", "Taking", "Police power"], answer: 1, explanation: "Eminent domain is the right of the government to take private property for public use. Condemnation is the legal process used to exercise that right. (Source: U.S. Constitution, Fifth Amendment)" },
    { question: "A variance allows:", options: ["A change in zoning classification", "Relief from strict compliance with zoning due to hardship", "A special use approved in zoning", "Nonconforming use to expand"], answer: 1, explanation: "A variance is a deviation from a specific zoning ordinance (like setbacks) granted when strict enforcement would impose an undue hardship on the property owner. (Source: Principles of Land Use Control)" },
    { question: "A special exception (conditional use) allows:", options: ["A use permitted if specific conditions are met", "Relief due to hardship", "A downzoning", "A spot zoning"], answer: 0, explanation: "A special exception allows a property to be used in a way that is not automatically permitted but is allowable if certain conditions outlined in the zoning ordinance are met. (Source: Principles of Land Use Control)" },
    { question: "A net listing in Florida is:", options: ["Illegal", "Legal but can create conflicts; use with caution", "Only for commercial", "Only for auctions"], answer: 1, explanation: "Net listings are legal in Florida but are discouraged because they can create a conflict of interest between the broker's fiduciary duty and their own financial gain. (Source: Real Estate Practice)" },
    { question: "An exclusive-right-of-sale listing means:", options: ["Broker paid only if the broker procures buyer", "Broker paid regardless of who procures buyer during listing term", "Owner always pays no commission", "Open listing arrangement"], answer: 1, explanation: "This type of listing provides the most protection to the broker, as they are entitled to a commission if the property sells during the listing period, regardless of who finds the buyer. (Source: Real Estate Practice)" },
    { question: "A protection period clause requires the broker to:", options: ["File a lien", "Provide a list of prospects to seller within specified time", "Record the listing", "Extend the listing automatically"], answer: 1, explanation: "To enforce a protection clause, the broker must provide the seller with a list of prospective buyers they negotiated with during the listing term, usually within a specified number of days after expiration. (Source: Real Estate Practice)" },
    { question: "A counteroffer:", options: ["Keeps the original offer open", "Terminates the original offer", "Has no effect on the offer", "Becomes an acceptance"], answer: 1, explanation: "A counteroffer is a rejection of the original offer and the simultaneous creation of a new offer. The original offer is dead and cannot be revived. (Source: General Contract Law)" },
    { question: "Liquidated damages in a sale contract typically allow the seller to keep:", options: ["Broker’s commission", "The earnest money deposit", "Appraisal fee", "Title premium"], answer: 1, explanation: "Liquidated damages are a pre-agreed amount of money that one party will receive if the other party breaches the contract. In real estate, this is almost always the buyer's earnest money deposit. (Source: General Contract Law)" },
    { question: "Lead-based paint disclosure is required for residential housing built:", options: ["After 1978", "Before 1978", "Before 1970", "Any age"], answer: 1, explanation: "Federal law requires disclosure of known lead-based paint and hazards for residential properties built before 1978. (Source: Residential Lead-Based Paint Hazard Reduction Act)" },
    { question: "The Fair Housing Act protects all except:", options: ["Race, color, religion", "Sex, national origin", "Handicap, familial status", "Age"], answer: 3, explanation: "Age is not a protected class under the federal Fair Housing Act. (Source: Fair Housing Act)" },
    { question: "Redlining refers to:", options: ["Steering buyers", "Panic selling", "Lenders refusing loans in certain areas", "Appraisers declining assignments"], answer: 2, explanation: "Redlining is the illegal practice of a lender refusing to make loans or providing different terms for properties in certain areas, often based on the racial or ethnic composition of the neighborhood. (Source: Fair Housing Act)" },
    { question: "Steering occurs when:", options: ["Directing buyers to or away from neighborhoods based on protected class", "Price fixing", "Exclusive territories", "Bid rigging"], answer: 0, explanation: "Steering is the illegal act of channeling homebuyers toward or away from particular neighborhoods based on their protected class status. (Source: Fair Housing Act)" },
    { question: "Blockbusting is:", options: ["Inducing owners to sell due to entry of protected classes", "Steering", "Tying arrangements", "Vertical price fixing"], answer: 0, explanation: "Blockbusting (or panic selling) is the illegal practice of inducing homeowners to sell by making representations about the entry of protected classes into a neighborhood. (Source: Fair Housing Act)" },
    { question: "RESPA prohibits:", options: ["Usury", "Discrimination in lending", "Kickbacks and unearned fees in settlement services", "Redlining"], answer: 2, explanation: "The Real Estate Settlement Procedures Act (RESPA) specifically prohibits kickbacks and unearned fees between settlement service providers. (Source: RESPA)" },
    { question: "TILA requires disclosure of:", options: ["APR and finance charges for consumer credit", "Property condition", "Zoning compliance", "Flood insurance"], answer: 0, explanation: "The Truth in Lending Act (TILA), implemented by Regulation Z, requires lenders to disclose the true cost of credit, including the Annual Percentage Rate (APR) and total finance charges. (Source: TILA)" },
    { question: "An estoppel certificate is used to:", options: ["Release a lien", "Confirm the terms and balance of an existing lease or loan", "Transfer title", "Record a deed"], answer: 1, explanation: "An estoppel certificate is a legal document used to verify key facts, such as the current loan balance or lease terms, preventing a party from later claiming they are different. (Source: Real Estate Practice)" },
    { question: "The probable cause panel of FREC acts like:", options: ["A grand jury to determine if probable cause exists", "Final authority", "Arbitrator", "Mediator"], answer: 0, explanation: "The probable cause panel reviews investigation reports and acts like a grand jury, determining if there is sufficient evidence (probable cause) to proceed with a formal administrative complaint. (Source: F.S. 455.225)" },
    { question: "An executed contract is:", options: ["Fully performed by both parties", "Signed but not delivered", "Voidable", "In breach"], answer: 0, explanation: "An executed contract is one where all parties have fulfilled their contractual obligations. (Source: General Contract Law)" },
    { question: "An executory contract is:", options: ["Fully performed", "One or more obligations remain", "Invalid", "Illegal"], answer: 1, explanation: "An executory contract is one where some performance or obligation remains to be completed by one or more parties. (Source: General Contract Law)" },
    { question: "A broker’s escrow account may be held in:", options: ["A Florida bank, savings association, or credit union", "A title company’s trust account", "An attorney’s trust account", "Any of the above (if properly designated)"], answer: 3, explanation: "A broker can place escrow funds in a Florida-based bank, savings association, credit union, or, with the consent of all parties, a Florida title company or attorney's trust account. (Source: F.A.C. 61J2-14.008)" },
    { question: "A sales associate forming a PA/LLC/PLLC must:", options: ["Register it with the DBPR and have the license issued in that legal name", "Use any trade name", "Be taxed as C-corp only", "Not notify FREC"], answer: 0, explanation: "The legal entity (PA, LLC, or PLLC) must be registered with the Department of State, and then the real estate license must be issued in the licensee's legal name, followed by the entity designation. (Source: F.S. 621.05)" },
    { question: "A broker changing business address must notify the DBPR within:", options: ["10 days", "24 hours", "30 days", "Next renewal"], answer: 0, explanation: "A broker must notify the DBPR of a change in business address within 10 days of the change. (Source: F.S. 475.23)" },
    { question: "A nonresident licensed in Florida who moves out of state must:", options: ["Surrender license", "File the irrevocable consent to service of process and keep DBPR informed", "Re-test", "Do nothing"], answer: 1, explanation: "All non-resident licensees must file an irrevocable consent to service, agreeing that legal actions can be initiated against them in Florida. They must also keep their address current. (Source: F.S. 475.180)" },
    { question: "Homestead protections in Florida include:", options: ["Protection from all creditors", "Protection from forced sale by certain creditors; exceptions include tax liens, mortgages, mechanics’ liens", "Total tax exemption", "Automatic portability"], answer: 1, explanation: "The homestead protection shields a primary residence from forced sale by many creditors, but it does not protect against foreclosure for non-payment of property taxes, mortgages, or construction liens. (Source: Florida Constitution, Art. X, Sec. 4)" },
    { question: "A condominium resale buyer has the right to cancel within:", options: ["10 days", "3 business days after receipt of required documents", "7 calendar days", "15 calendar days"], answer: 1, explanation: "For the resale of a condominium unit, the buyer has a 3-business-day right of rescission after receiving the required condominium documents. (Source: F.S. 718.503)" },
    { question: "A new condo from a developer generally includes a cancellation period of:", options: ["3 business days", "15 calendar days", "10 calendar days", "7 business days"], answer: 1, explanation: "When purchasing a new condominium unit from a developer, the buyer has a 15-calendar-day cancellation period after receiving the required documents. (Source: F.S. 718.503)" },
    { question: "A buyer of a new timeshare has how many days to cancel without penalty?", options: ["3", "5", "10", "15"], answer: 2, explanation: "A purchaser of a new timeshare has the right to cancel the contract within 10 calendar days of signing the contract or receiving the public offering statement, whichever is later. (Source: F.S. 721.10)" },
    { question: "A mortgagee is the:", options: ["Borrower", "Lender", "Trustee", "Grantee"], answer: 1, explanation: "The mortgagee is the lender (receives the mortgage). The mortgagor is the borrower (gives the mortgage). (Source: Principles of Real Estate Finance)" },
    { question: "RESIDENTIAL property in Florida is defined as:", options: ["Improved residential property up to 4 units, vacant land zoned for up to 4 units, agricultural ≤10 acres", "Any property", "5+ units", "Industrial only"], answer: 0, explanation: "This specific definition is used for determining when certain disclosures and brokerage relationships apply. It is broader than just a single-family home. (Source: F.S. 475.01)" },
    { question: "Investment value is:", options: ["Market value", "Value to a specific investor", "Assessed value", "Insurable value"], answer: 1, explanation: "Investment value is the value of a property to a particular investor, based on their individual investment criteria, such as their required rate of return. (Source: Appraisal Principles)" },
    { question: "A cost approach replacement method typically uses:", options: ["Historical cost", "Reproduction or replacement cost new − depreciation + land value", "Mortgage balance + equity", "Sales comparison only"], answer: 1, explanation: "The formula for the cost approach is: Cost to build new (either reproduction or replacement) minus accrued depreciation, plus the value of the land. (Source: Appraisal Principles)" },
    { question: "Under Florida law, a broker must review and sign:", options: ["All settlement statements", "All brokerage-related advertising", "All listings and offers prepared by associates", "All appraisals"], answer: 2, explanation: "A broker has a duty to supervise their associates, which includes reviewing and signing all listing agreements, offers, and other contracts prepared by them in a timely manner. (Source: F.A.C. 61J2-3.015)" },
    { question: "A broker performing property management must handle security deposits under Ch. 83 by:", options: ["Commingling with rent in operating account", "Placing in a separate Florida account (interest-bearing or noninterest-bearing) or posting a surety bond and following notice requirements", "Sending to landlord directly without record", "Holding out-of-state"], answer: 1, explanation: "Chapter 83, F.S. (Landlord and Tenant Act) provides strict rules for handling tenant deposits, including holding them in a separate account or posting a bond, and giving proper notice to the tenant. (Source: F.S. 83.49)" }
],
exam9: [
    { question: "A sales associate applicant is NOT required to comply with which requirement?", options: ["Be 18 years or older", "Possess a high school diploma or equivalent", "Be a Florida resident", "Have a United States Social Security number"], answer: 2, explanation: "An applicant for a Florida real estate license is not required to be a resident of the state. They must, however, be at least 18, have a high school diploma or equivalent, and possess a U.S. Social Security number. (Source: Florida Statute 475.17(2))" },
    { question: "The maximum payment from the Real Estate Recovery Fund for a single transaction is?", options: ["$50,000", "$75,000", "$100,000", "$150,000"], answer: 0, explanation: "The Real Estate Recovery Fund is capped at paying $50,000 for a single real estate transaction. The maximum aggregate amount that can be paid on behalf of a single licensee for multiple transactions is $150,000. (Source: Florida Statute 475.484(1)(a))" },
    { question: "Which entity issues real estate licenses in Florida?", options: ["The Governor", "The Florida Real Estate Commission (FREC)", "The Department of Business and Professional Regulation (DBPR)", "The Division of Real Estate (DRE)"], answer: 2, explanation: "While the Florida Real Estate Commission (FREC) sets the rules, the Department of Business and Professional Regulation (DBPR) is the state agency responsible for the actual issuance and renewal of all professional licenses, including real estate. (Source: Florida Statute 455.203)" },
    { question: "A broker must deposit escrow funds into the escrow account no later than?", options: ["End of next business day", "End of third business day", "End of fifth business day", "Immediately upon receipt"], answer: 1, explanation: "A sales associate must give escrow funds to their broker by the end of the next business day. The broker then has until the end of the third business day (from receipt by the associate) to deposit them into an escrow account. (Source: F.A.C. 61J2-14.009)" },
    { question: "Which business structure may NOT register as a brokerage?", options: ["Corporation", "General partnership", "Joint venture", "Limited liability partnership (LLP)"], answer: 2, explanation: "A joint venture is a temporary business arrangement and cannot be registered as a real estate brokerage in Florida. Other unregisterable entities include a corporation sole and a business trust. (Source: Florida Statute 475.15)" },
    { question: "If a broker accepts an EDO and later wins in court, the broker is entitled to what?", options: ["Compensation", "Indemnification", "Reimbursement", "Damages"], answer: 2, explanation: "If a broker correctly follows an Escrow Disbursement Order (EDO) and is later sued, the Real Estate Recovery Fund will cover the broker's court costs and attorney's fees. This is a reimbursement of the broker's expenses. (Source: Florida Statute 475.484(1)(c))" },
    { question: "In a nonresidential transaction, designated sales associates may be used if?", options: ["Both buyer and seller request it", "Both must each have assets of $1 million", "The broker has written consent", "The buyer and seller sign disclosure notice stating assets meet threshold"], answer: 1, explanation: "The fundamental requirement for using designated sales associates is that the buyer and seller must each have assets of at least $1 million. They must then request this form of representation and sign a disclosure notice attesting to this fact. (Source: Florida Statute 475.2755(1))" },
    { question: "Which of the following is NOT a duty in a no brokerage relationship?", options: ["Deal honestly and fairly", "Account for all funds", "Disclose all known material defects", "Present all offers and counteroffers"], answer: 3, explanation: "A licensee in a 'no brokerage' capacity has only three duties: Deal honestly, account for funds, and disclose known material defects. The duty to present all offers and counteroffers is required in transaction broker and single agent relationships. (Source: Florida Statute 475.278(1))" },
    { question: "Office signs must contain the broker’s trade name, broker’s name, and the words?", options: ["Licensed Broker", "Licensed Real Estate Broker", "Real Estate Broker", "Realtor"], answer: 1, explanation: "Florida law requires that brokerage office signs clearly display the brokerage trade name, the registered broker's name, and the words 'Licensed Real Estate Broker' or 'Lic. Real Estate Broker'. (Source: Florida Statute 475.22(1))" },
    { question: "If a postdated check is accepted as earnest money, the broker must?", options: ["Deposit immediately", "Hold check in safe place until date on check", "Obtain seller’s approval before acceptance", "Return check to buyer"], answer: 2, explanation: "A broker cannot accept a postdated check as an earnest money deposit without first getting the express permission of the seller. (Source: F.A.C. 61J2-14.008(3))" },
    { question: "Save Our Homes (SOH) benefit is portable, meaning homeowners may?", options: ["Transfer it to children", "Transfer tax savings to new homestead", "Apply it to investment property", "Use it for commercial property"], answer: 1, explanation: "SOH portability allows a homeowner to transfer up to $500,000 of the accumulated tax savings (the difference between assessed value and market value) from their previous homestead to a new homestead in Florida. (Source: Florida Statute 193.155(8))" },
    { question: "In the government survey system, the strip of land six miles wide located immediately south of the baseline is?", options: ["Range 1 South", "Tier 6 South", "Tier 1 South", "Township 1 South"], answer: 2, explanation: "The Government Survey System uses a grid. The horizontal (east-west) lines create six-mile-wide strips called tiers. The first strip south of the main baseline is designated Tier 1 South (T1S). Strips of land running north-south are called Ranges. (Source: Principles of Land Description)" },
    { question: "Broker post-licensing requirement is how many hours?", options: ["14 hours", "30 hours", "45 hours", "60 hours"], answer: 3, explanation: "Newly licensed brokers must complete 60 hours of FREC-approved post-licensing education before their first license renewal deadline. (Sales associates must complete 45 hours). (Source: Florida Statute 475.17(3)(a))" },
    { question: "What is the maximum suspension FREC may impose against a licensee for a first violation?", options: ["1 year", "5 years", "10 years", "Permanent"], answer: 2, explanation: "The Florida Real Estate Commission (FREC) has the authority to suspend a real estate license for a maximum period of 10 years. Revocation is permanent. (Source: Florida Statute 475.25(1))" },
    { question: "A developer wishes to change an area zoned for agriculture to residential. This is called?", options: ["Variance", "Special exception", "Zoning amendment", "Buffer zone"], answer: 2, explanation: "Changing the permitted use of an area, such as from agricultural to residential, requires a formal change to the zoning map, which is known as a zoning amendment or rezoning. (Source: Principles of Land Use Control)" },
    { question: "Permission to deviate from a zoning ordinance to avoid hardship is called?", options: ["Variance", "Special exception", "Zoning change", "Nonconforming use"], answer: 0, explanation: "A variance is an exception granted to a property owner to deviate from a specific zoning rule (e.g., setback requirements) when strict enforcement would create an undue hardship. (Source: Principles of Land Use Control)" },
    { question: "An executory contract is one that?", options: ["Has been fully performed", "Has been declared void", "Is not yet fully performed", "Is unenforceable"], answer: 2, explanation: "An executory contract is an agreement where one or more parties still have duties to perform. Once all obligations are completed, it becomes an 'executed' contract. (Source: General Contract Law)" },
    { question: "Highest and Best Use means?", options: ["Most profitable, legally permissible, physically possible, financially feasible use", "Use that produces highest tax revenue", "Use chosen by zoning authority", "Owner’s intended use"], answer: 0, explanation: "This is the standard definition used in appraisal. The Highest and Best Use of a property is the single use that is legally permissible, physically possible, financially feasible, and results in the highest value. (Source: The Appraisal Foundation - USPAP)" },
    { question: "A broker's license was involuntarily inactive for 14 months. To reactivate, the broker must complete:", options: ["14 hours of CE", "28 hours of reactivation education", "60 hours of post-licensing", "The 72-hour pre-license course"], answer: 1, explanation: "For a license that has been involuntarily inactive for more than 12 months but less than 24 months, the licensee must complete a 28-hour reactivation course. (Source: F.A.C. 61J2-3.010)" },
    { question: "Which of the following is an example of a specific lien?", options: ["Judgment lien", "Vendor's lien", "Income tax lien", "Estate tax lien"], answer: 1, explanation: "A vendor's lien is a specific lien, meaning it attaches to a specific property. The other options are general liens, which attach to all of a debtor's property. (Source: Florida Lien Law)" },
    { question: "The clause in a deed that specifies the type of estate being transferred is the:", options: ["Granting clause", "Seisin clause", "Habendum clause", "Reddendum clause"], answer: 2, explanation: "The Habendum clause, which typically begins with 'To have and to hold,' defines the extent of ownership interest being conveyed. (Source: Principles of Real Property)" },
    { question: "A property has a Net Operating Income of $80,000 and a market value of $1,000,000. What is the capitalization rate?", options: ["7%", "8%", "9%", "10%"], answer: 1, explanation: "The formula is Rate = Income / Value. $80,000 (NOI) / $1,000,000 (Value) = 0.08, or 8%. (Source: Appraisal Principles)" },
    { question: "A broker who is a single agent for a seller has a duty of:", options: ["Limited confidentiality", "Full disclosure to the principal", "Obedience to the buyer", "Honesty to all parties"], answer: 1, explanation: "A single agent owes the fiduciary duty of full disclosure to their principal, meaning they must disclose all known facts that might reasonably affect the principal's decision. (Source: Florida Statute 475.278(2))" },
    { question: "What is the statute of limitations for a written contract in Florida?", options: ["3 years", "4 years", "5 years", "7 years"], answer: 2, explanation: "The statute of limitations for bringing legal action on a written contract in Florida is five years. For an oral contract, it is four years. (Source: Florida Statute 95.11)" },
    { question: "The Fair Housing Act of 1968, as amended, prohibits discrimination based on all of the following EXCEPT:", options: ["Race", "Religion", "Age", "Familial status"], answer: 2, explanation: "Age is not a protected class under the Fair Housing Act. The protected classes are race, color, religion, sex, national origin, disability, and familial status. (Source: Fair Housing Act)" },
    { question: "The primary purpose of the primary mortgage market is to:", options: ["Buy and sell existing mortgages", "Originate new mortgage loans", "Insure mortgage loans", "Guarantee mortgage loans"], answer: 1, explanation: "The primary mortgage market is where lenders, such as banks and credit unions, directly originate new loans for borrowers. The secondary market is where these loans are later bought and sold. (Source: Principles of Real Estate Finance)" },
    { question: "A sales associate's license will become void if they fail to complete:", options: ["14-hour continuing education", "45-hour post-licensing education", "28-hour reactivation education", "The state exam"], answer: 1, explanation: "A sales associate's initial license is considered null and void if they do not complete the required 45-hour post-licensing course before their first renewal deadline. (Source: Florida Statute 475.17(3))" },
    { question: "Which legal description uses a principal meridian and a baseline?", options: ["Metes and bounds", "Lot and block", "Government survey system", "Tax map"], answer: 2, explanation: "The Government Survey System (or Rectangular Survey System) is based on a grid of intersecting principal meridians (north-south) and baselines (east-west). (Source: Principles of Land Description)" },
    { question: "A broker is sued for misrepresentation. The court awards the plaintiff $40,000 in compensatory damages and $20,000 in punitive damages. How much can be paid from the Recovery Fund?", options: ["$20,000", "$40,000", "$50,000", "$60,000"], answer: 1, explanation: "The Recovery Fund can pay for actual or compensatory damages up to the $50,000 limit per transaction. It does not cover punitive damages, interest, or court costs. Therefore, the maximum payable is the $40,000 in compensatory damages. (Source: Florida Statute 475.484)" },
    { question: "A landlord who places a security deposit in an interest-bearing account must pay the tenant:", options: ["5% simple interest annually or 75% of interest earned", "100% of the interest earned", "A flat rate set by the DBPR", "No interest is required to be paid"], answer: 0, explanation: "If a landlord holds a security deposit in an interest-bearing account, they must pay the tenant at least 75% of the annualized average interest rate earned, or 5% per year simple interest, whichever the landlord chooses. (Source: Florida Statute 83.49(1)(b))" },
    { question: "Which of the following is a characteristic of the real estate market?", options: ["Homogeneous product", "Quick to respond to changes in supply and demand", "Immobility of the product", "Centralized market"], answer: 2, explanation: "Real estate is immobile; it cannot be moved. This is a fundamental physical and economic characteristic that distinguishes it from other markets. (Source: Principles of Real Estate)" },
    { question: "A broker's advertisement must include the:", options: ["Broker's personal phone number", "Name of the sales associate", "Licensed name of the brokerage firm", "Property address"], answer: 2, explanation: "All real estate advertisements must include the licensed name of the brokerage firm. Failing to do so is considered a blind advertisement and is illegal. (Source: F.A.C. 61J2-10.025)" },
    { question: "The process of land buildup from water-borne rock, sand, and soil is:", options: ["Erosion", "Alluvion", "Accretion", "Reliction"], answer: 2, explanation: "Accretion is the process of gradual land buildup. The resulting new land is called alluvion. (Source: Principles of Real Property)" },
    { question: "Which of the following is a requirement for a valid real estate contract?", options: ["Must be notarized", "Must be in writing and signed", "Must be recorded", "Must have earnest money"], answer: 1, explanation: "Under the Statute of Frauds, contracts for the sale of real estate must be in writing and signed by the party to be charged to be enforceable. (Source: Florida Statute 725.01)" },
    { question: "A developer of 25 or more new residential condominium units must provide buyers with a:", options: ["Prospectus", "Proprietary lease", "Estimated operating budget", "Governance form"], answer: 0, explanation: "For new residential condos of 25+ units, the developer must provide the buyer with a prospectus, which contains detailed information about the condominium. (Source: Florida Statute 718.503)" },
    { question: "The FREC's power to enact rules and regulations is an example of its:", options: ["Executive power", "Quasi-judicial power", "Quasi-legislative power", "Ministerial power"], answer: 2, explanation: "The FREC's authority to create and pass rules to implement Florida statutes is its quasi-legislative power. Its power to discipline licensees is quasi-judicial. (Source: Florida Statute 475.05)" },
    { question: "If a broker has conflicting demands on escrowed funds, they must notify the FREC within:", options: ["5 business days", "10 business days", "15 business days", "30 business days"], answer: 2, explanation: "A broker must give written notification to the FREC within 15 business days of receiving conflicting demands for an escrow deposit. (Source: F.A.C. 61J2-14.012)" },
    { question: "Which of the following is an example of functional obsolescence?", options: ["A cracked foundation", "A property located next to a noisy airport", "A five-bedroom house with only one bathroom", "Worn-out carpeting"], answer: 2, explanation: "Functional obsolescence is a loss in value due to a poor design, outdated features, or a layout that does not function well by modern standards. (Source: Appraisal Principles)" },
    { question: "The documentary stamp tax on a deed is calculated based on the:", options: ["Loan amount", "Appraised value", "Sale price", "Assessed value"], answer: 2, explanation: "The documentary stamp tax on a deed is paid on the full purchase price of the property. (Source: Florida Statute 201.02)" },
    { question: "A licensee who changes their mailing address must notify the DBPR within:", options: ["10 days", "15 days", "30 days", "60 days"], answer: 0, explanation: "All licensees must notify the DBPR in writing of any change in their current mailing address within 10 days after the change. (Source: Florida Statute 455.275(1))" },
    { question: "Which type of tenancy includes the right of survivorship?", options: ["Tenancy in common", "Joint tenancy", "Tenancy at will", "Estate for years"], answer: 1, explanation: "A key feature of a joint tenancy is the right of survivorship, which means that when one joint tenant dies, their interest automatically passes to the surviving joint tenant(s). (Source: Principles of Real Property)" },
    { question: "The act of taking private property for public use through the government's power of eminent domain is called:", options: ["Escheat", "Foreclosure", "Dedication", "Condemnation"], answer: 3, explanation: "Condemnation is the legal process through which the government exercises its right of eminent domain to acquire private property for public use. (Source: U.S. Constitution, Fifth Amendment)" },
    { question: "A sales associate's first license renewal requires completion of:", options: ["14 hours of CE", "28 hours of reactivation", "45 hours of post-licensing", "60 hours of post-licensing"], answer: 2, explanation: "Sales associates must complete a 45-hour post-licensing course before their first license renewal. Brokers must complete a 60-hour course. (Source: Florida Statute 475.17)" },
    { question: "Which of the following is a general lien?", options: ["Property tax lien", "Special assessment lien", "Construction lien", "Judgment lien"], answer: 3, explanation: "A judgment lien is a general lien because it attaches to all of the debtor's property, both real and personal. The other options are specific liens that attach only to a particular property. (Source: Florida Lien Law)" },
    { question: "A violation for which the FREC may issue a notice of noncompliance is a:", options: ["First-time minor violation", "Violation involving fraud", "Violation that endangers the public", "Second offense"], answer: 0, explanation: "A notice of noncompliance is a warning for a first-time minor violation that does not demonstrate a serious inability to practice. The licensee has 15 days to correct it. (Source: Florida Statute 455.225(3))" },
    { question: "The component of an adjustable-rate mortgage that is added to the index to determine the interest rate is the:", options: ["Cap", "Margin", "Teaser rate", "Point"], answer: 1, explanation: "The fully indexed rate of an ARM is calculated by adding the index (which can change) to the margin (which is constant). (Source: Principles of Real Estate Finance)" },
    { question: "A real estate license is required for all of the following activities EXCEPT:", options: ["Selling a business with an interest in real property", "Auctioning farmland", "Renting a mobile home on a rented lot", "Selling cemetery lots"], answer: 3, explanation: "A person selling cemetery lots is specifically exempt from needing a real estate license in Florida. (Source: Florida Statute 475.011(1))" },
    { question: "A broker who is a transaction broker has a duty of:", options: ["Undivided loyalty", "Full confidentiality", "Obedience", "Limited confidentiality"], answer: 3, explanation: "A transaction broker owes limited confidentiality to both parties, which prevents the disclosure of price, terms, or motivation of either party without permission. (Source: Florida Statute 475.278(3))" },
    { question: "The term for a property that has been on the market for a long time without selling is:", options: ["Stale", "Distressed", "Stigmatized", "Obsolete"], answer: 0, explanation: "In real estate terminology, a property that remains unsold for an extended period is often referred to as a 'stale' listing. (Source: Real Estate Practice)" },
    { question: "What is the maximum fine the FREC can impose for a violation of F.S. 475?", options: ["$1,000", "$2,500", "$5,000", "$10,000"], answer: 2, explanation: "The Florida Real Estate Commission (FREC) has the authority to impose administrative fines of up to $5,000 per violation of Chapter 475 or Chapter 455, F.S. (Source: Florida Statute 475.25(1))" },
    { question: "A property's value is being negatively impacted by the poor condition of neighboring properties. This is an example of:", options: ["Regression", "Progression", "Substitution", "Conformity"], answer: 0, explanation: "The principle of regression states that the value of a superior property is adversely affected by its association with inferior properties in the same neighborhood. (Source: Appraisal Principles)" },
    { question: "A sales associate can be a stockholder in a brokerage corporation but may not be a(n):", options: ["Shareholder", "Employee", "Officer or director", "Independent contractor"], answer: 2, explanation: "Only licensed brokers can be officers or directors of a real estate brokerage corporation. Sales associates can be shareholders. (Source: Florida Statute 475.15)" },
    { question: "The federal law that requires lenders to provide borrowers with a Closing Disclosure is:", options: ["The Fair Housing Act", "The Equal Credit Opportunity Act", "The Real Estate Settlement Procedures Act (RESPA)", "The Truth in Lending Act (TILA)"], answer: 2, explanation: "RESPA, through the TILA-RESPA Integrated Disclosure (TRID) rule, requires lenders to provide the Closing Disclosure to borrowers at least three business days before closing. (Source: RESPA)" },
    { question: "Which of the following is an example of a unilateral contract?", options: ["A sales contract", "An exclusive right-of-sale listing", "An open listing", "A lease agreement"], answer: 2, explanation: "An open listing is a unilateral contract because only one party (the seller) makes a promise. The broker is not obligated to act, but if they do and are the procuring cause of the sale, the seller must pay the commission. (Source: General Contract Law)" },
    { question: "The state's power to enact laws to protect the public health, safety, and welfare is known as:", options: ["Eminent domain", "Police power", "Escheat", "Taxation"], answer: 1, explanation: "Police power is the inherent authority of the government to adopt and enforce laws for the protection of the public health, safety, morals, and general welfare. Zoning is a primary example. (Source: U.S. Constitutional Law)" },
    { question: "A property has an effective gross income of $120,000 and operating expenses of $50,000. The debt service is $40,000. What is the before-tax cash flow (cash throw-off)?", options: ["$30,000", "$70,000", "$80,000", "$120,000"], answer: 0, explanation: "The formula is: Effective Gross Income - Operating Expenses = NOI. Then, NOI - Debt Service = Before-Tax Cash Flow. So, $120,000 - $50,000 = $70,000 (NOI). $70,000 - $40,000 = $30,000. (Source: Real Estate Investment Analysis)" },
    { question: "The intangible tax is levied on:", options: ["The deed", "The sales contract", "New real estate mortgages", "The property's assessed value"], answer: 2, explanation: "Florida's intangible tax is a one-time tax paid on new mortgages at the rate of 2 mills ($0.002) per dollar of the new loan amount. (Source: Florida Statute 199.133)" },
    { question: "A broker who induces a homeowner to sell by making representations that minority groups are moving into the neighborhood is guilty of:", options: ["Steering", "Redlining", "Blockbusting", "Price fixing"], answer: 2, explanation: "Blockbusting, or panic selling, is the illegal practice of inducing homeowners to sell their properties by making representations regarding the entry or prospective entry of persons of a particular protected class into the neighborhood. (Source: Fair Housing Act)" },
    { question: "If a husband and wife own property as tenants by the entireties and the husband dies, what is the status of the property ownership?", options: ["The wife owns the property in severalty.", "The wife becomes a tenant in common with the husband's heirs.", "The property must be probated.", "The wife owns a life estate."], answer: 0, explanation: "Tenancy by the entireties includes an automatic right of survivorship. Upon the death of one spouse, the surviving spouse automatically owns the entire property in severalty (sole ownership). (Source: Principles of Real Property)" },
    { question: "A broker is required to maintain business records, including escrow account records, for how long?", options: ["One year", "Three years", "Five years", "Seven years"], answer: 2, explanation: "Florida law requires brokers to preserve business records for at least five years from the date of receipt of any money, fund, deposit, check, or draft. (Source: Florida Statute 475.5015)" },
    { question: "Which of the following is a voidable contract?", options: ["A contract for an illegal purpose.", "A contract signed by a minor.", "An oral contract to sell real estate.", "A contract that has been fully performed."], answer: 1, explanation: "A contract entered into with a minor is voidable by the minor. This means the minor can choose to enforce or void the contract. (Source: General Contract Law)" },
    { question: "The Government National Mortgage Association (Ginnie Mae) primarily:", options: ["Buys conventional mortgages.", "Guarantees mortgage-backed securities backed by FHA and VA loans.", "Originates FHA loans.", "Insures conventional loans."], answer: 1, explanation: "Ginnie Mae's main function is to guarantee the timely payment of principal and interest on mortgage-backed securities (MBS) that are collateralized by FHA, VA, and other government-backed loans. (Source: Principles of Real Estate Finance)" },
    { question: "A complaint against a licensee is legally sufficient if it alleges a violation of:", options: ["The REALTOR® Code of Ethics", "A local board rule", "A Florida statute or FREC rule", "A verbal promise"], answer: 2, explanation: "A complaint is legally sufficient if it contains facts indicating that a violation of a Florida statute, a DBPR rule, or a FREC rule has occurred. (Source: Florida Statute 455.225)" },
    { question: "A broker who is acting as an escrow agent receives an Escrow Disbursement Order from the FREC. The broker must:", options: ["Wait 10 days before disbursing.", "Notify all parties of the intended disbursement.", "Follow the instructions of the EDO.", "Get a second opinion from an attorney."], answer: 2, explanation: "An Escrow Disbursement Order (EDO) is a binding legal order from the FREC. The broker must follow its instructions and is protected from liability for doing so. (Source: Florida Statute 475.25(1)(d))" },
    { question: "The term 'ad valorem' means:", options: ["According to value", "For the public good", "Let the buyer beware", "As is"], answer: 0, explanation: "'Ad valorem' is Latin for 'according to value.' Property taxes are ad valorem taxes because they are based on the assessed value of the property. (Source: Black's Law Dictionary)" },
    { question: "A sales associate's compensation is set by:", options: ["The FREC", "Florida law", "The local board of REALTORS®", "Agreement between the broker and the sales associate"], answer: 3, explanation: "Compensation for a sales associate is determined by the employment or independent contractor agreement between the associate and their employing broker. (Source: Real Estate Practice)" },
    { question: "Which of the following would terminate an offer to purchase real estate?", options: ["A poor home inspection report", "The buyer's inability to get financing", "A counteroffer from the seller", "The buyer changing their mind before acceptance"], answer: 2, explanation: "A counteroffer is a rejection of the original offer and the simultaneous creation of a new offer. This terminates the original offer. (Source: General Contract Law)" },
    { question: "The interest that a person has in a property when they have signed a contract to purchase but have not yet closed is called:", options: ["Legal title", "Equitable title", "A life estate", "A remainder interest"], answer: 1, explanation: "Equitable title is the buyer's interest in a property from the time the contract is signed until closing. Legal title is transferred at closing with the deed. (Source: Principles of Real Property)" },
    { question: "A broker is required to open and maintain an escrow account in a:", options: ["Florida-based bank, savings association, or credit union", "Stock brokerage firm", "Personal checking account", "Safe deposit box"], answer: 0, explanation: "An escrow account must be held in a Florida-based title company, banking institution, credit union, or savings and loan association. (Source: F.A.C. 61J2-14.008)" },
    { question: "The FREC's summary suspension power is used when:", options: ["A licensee fails to pay a fine.", "A licensee is found to be an immediate serious danger to the public.", "A complaint is filed against a broker.", "A licensee fails to renew their license."], answer: 1, explanation: "A summary (or emergency) suspension is an order issued by the Secretary of the DBPR when a licensee's actions are deemed an immediate serious danger to the public health, safety, or welfare. (Source: Florida Statute 455.225(8))" },
    { question: "Which of the following is a leasehold estate?", options: ["Fee simple estate", "Life estate", "Estate for years", "Remainder estate"], answer: 2, explanation: "An estate for years is a type of leasehold estate with a specific starting and ending date. The other options are freehold estates, which involve ownership. (Source: Principles of Real Property)" },
    { question: "The process of valuing a business, including its tangible and intangible assets, is known as:", options: ["Appraisal", "Business valuation", "Liquidation analysis", "Going concern value"], answer: 1, explanation: "Business valuation is the process of determining the economic value of a business or company. It includes analyzing all assets, liabilities, and income potential. (Source: Business Brokerage Principles)" },
    { question: "A sales associate who is licensed with a broker can also work for which other entity at the same time?", options: ["Another real estate broker", "An owner-developer who is registered with the DBPR", "A mortgage company", "A title insurance company"], answer: 1, explanation: "A sales associate can only have one registered employer at a time, which is typically a broker. However, they can also work for an owner-developer who is registered with the DBPR, as this does not require registering under the developer as a broker. (Source: Florida Statute 475.25(1)(g))" },
    { question: "Which of the following is an example of external obsolescence?", options: ["An outdated kitchen", "A leaking roof", "A nearby highway causing constant noise", "A poor floor plan"], answer: 2, explanation: "External (or economic) obsolescence is a loss of value due to factors outside the property's boundaries, such as airport noise, a nearby landfill, or a major economic downturn. (Source: Appraisal Principles)" },
    { question: "A licensee who has been found guilty of a crime must notify the FREC within:", options: ["10 days", "15 days", "30 days", "45 days"], answer: 2, explanation: "A licensee must inform the FREC, in writing, within 30 days of being convicted or found guilty of, or entering a plea of nolo contendere (no contest) or guilty to, a crime in any jurisdiction. (Source: Florida Statute 455.227(1)(t))" },
    { question: "The 'subject to' clause in a mortgage transaction means:", options: ["The buyer is personally liable for the mortgage debt.", "The seller is released from liability for the mortgage debt.", "The buyer is taking title to the property but is not personally liable for the mortgage debt.", "The mortgage is being paid off at closing."], answer: 2, explanation: "When a buyer takes title 'subject to' an existing mortgage, they are not personally responsible for the loan. The seller remains primarily liable. If the buyer defaults, the lender can foreclose, but cannot sue the buyer for a deficiency judgment. (Source: Principles of Real Estate Finance)" },
    { question: "The Americans with Disabilities Act (ADA) requires property owners to:", options: ["Rent to individuals with disabilities over other applicants.", "Make all properties fully accessible, regardless of cost.", "Make reasonable accommodations and modifications for people with disabilities.", "Lower the rent for tenants with disabilities."], answer: 2, explanation: "The ADA requires owners of public accommodations and commercial facilities to make reasonable accommodations and allow for reasonable modifications to ensure equal access for individuals with disabilities. (Source: ADA)" },
    { question: "A broker is disciplined by the FREC. The broker's license could be all of the following EXCEPT:", options: ["Suspended", "Revoked", "Imprisoned", "Placed on probation"], answer: 2, explanation: "The FREC is an administrative agency and can impose administrative penalties like fines, suspension, revocation, and probation. It does not have the authority to impose criminal penalties such as imprisonment. (Source: Florida Statute 475.25)" },
    { question: "Which of the following is an economic characteristic of real estate?", options: ["Immobility", "Indestructibility", "Uniqueness", "Situs"], answer: 3, explanation: "Situs refers to the economic preference for a particular location, which is a key economic characteristic of real estate. The other options are physical characteristics. (Source: Principles of Real Estate)" },
    { question: "A licensee's failure to act in a trustworthy and honest manner is a violation of which duty?", options: ["The duty of skill, care, and diligence", "The duty of loyalty", "The duty of accounting for all funds", "The duty of good faith and fair dealing"], answer: 3, explanation: "All licensees have a fundamental duty to act with good faith, honesty, and fairness in all dealings. This is a core ethical and legal principle. (Source: Real Estate Practice)" },
    { question: "The final step in the appraisal process is to:", options: ["Estimate the land value", "Gather and analyze data", "Reconcile the values from the different approaches", "Prepare the appraisal report"], answer: 2, explanation: "After applying the three approaches to value (sales comparison, cost, and income), the appraiser's final step is to reconcile the different value indications into a single, final estimate of value. (Source: USPAP)" },
    { question: "Which of the following is considered a fixed operating expense in a property's income analysis?", options: ["Utilities", "Property Management Fees", "Property Taxes", "Maintenance and Repairs"], answer: 2, explanation: "Fixed expenses, such as property taxes and hazard insurance, do not fluctuate with the level of occupancy. Variable expenses, like utilities and maintenance, typically do. (Source: Appraisal Principles)" },
    { question: "The FREC's Probable Cause Panel is composed of:", options: ["Two current FREC members", "One current and one former FREC member", "Three DBPR investigators", "One FREC member and one licensed attorney"], answer: 0, explanation: "The Probable Cause Panel consists of two members appointed by the FREC Chairperson. At least one member must be a current member of the Commission. The other may be a current or a former FREC member. (Source: Florida Statute 455.225(4))" },
    { question: "A broker is preparing a closing statement. The property taxes for the year are $3,650 and have been paid by the seller. The closing is on May 1st (the 121st day of the year), and the day of closing belongs to the buyer. What is the proration for the property taxes?", options: ["$1,200 debit buyer, credit seller", "$2,450 debit seller, credit buyer", "$1,200 debit seller, credit buyer", "$2,450 debit buyer, credit seller"], answer: 3, explanation: "The buyer must reimburse the seller for the property taxes from the day of closing through the end of the year. Calculation: $3650 / 365 days = $10/day. The seller owned the property for 120 days. The buyer will own it for 365 - 120 = 245 days. The amount the buyer owes is $10/day * 245 days = $2,450. This is a debit to the buyer and a credit to the seller." },
    { question: "A broker is appraising a business using the income approach. Which of the following is NOT considered an intangible asset?", options: ["Goodwill", "Patents", "Accounts receivable", "Trademarks"], answer: 2, explanation: "Accounts receivable represent money owed to the business and are considered a current (tangible) asset, not an intangible asset like goodwill, patents, or trademarks. (Source: Business Brokerage Principles)" },
    { question: "A sales associate wants to be a director of a real estate brokerage corporation. This is:", options: ["Permitted if they own more than 10% of the stock.", "Permitted if they complete the broker's course.", "Not permitted under Florida law.", "Permitted if the broker gives written approval."], answer: 2, explanation: "Only licensed brokers can serve as officers or directors of a real estate brokerage corporation. A sales associate may be a shareholder but cannot hold a leadership position. (Source: Florida Statute 475.15)" },
    { question: "A broker is managing a property and has a tenant who has not paid rent. The broker must first:", options: ["File an eviction lawsuit.", "Change the locks on the property.", "Serve the tenant a written three-day notice to pay or vacate.", "Turn off the utilities."], answer: 2, explanation: "Before filing for eviction, Florida law requires the landlord or property manager to give the tenant a written three-day notice demanding payment of rent or possession of the premises. (Source: Florida Statute 83.56(3))" },
    { question: "What is the purpose of a subordination clause in a mortgage?", options: ["To allow the lender to increase the interest rate.", "To allow another mortgage to have a higher priority claim on the property.", "To release the borrower from personal liability.", "To require the entire loan balance to be paid upon sale."], answer: 1, explanation: "A subordination clause allows a subsequent mortgage to take a higher priority lien position than the mortgage containing the clause. This is often used in development and construction financing. (Source: Principles of Real Estate Finance)" },
    { question: "A broker is managing an escrow account. A monthly reconciliation of the account must be:", options: ["Sent to the FREC for review.", "Signed and dated by the broker.", "Notarized by a public official.", "Approved by all parties with funds in the account."], answer: 1, explanation: "The broker must review, sign, and date the monthly written reconciliation statement for each escrow account. This is a key part of the broker's supervisory duties. (Source: F.A.C. 61J2-14.012(2))" },
    { question: "A buyer purchases a rental property with existing tenants. The security deposits and advance rents:", options: ["Are returned to the tenants by the seller.", "Are transferred from the seller to the buyer at closing.", "Are forfeited to the seller.", "Are held by the closing agent in escrow."], answer: 1, explanation: "At closing, the seller must transfer all security deposits and advance rents to the buyer. The buyer then becomes responsible for holding these funds in accordance with Florida law. (Source: Florida Statute 83.49(7))" },
    { question: "A corporation sole is a way for _______ to hold title to real property.", options: ["A business partnership", "A married couple", "A religious organization", "A government entity"], answer: 2, explanation: "A corporation sole is a legal entity that allows a religious organization to hold title to property, typically in the name of the presiding clergy member (e.g., a bishop). It cannot be registered as a real estate brokerage. (Source: Florida Statute Chapter 617)" },
    { question: "Which type of title insurance policy is transferable?", options: ["Owner's policy", "Lender's (Mortgagee's) policy", "Leasehold policy", "Both Owner's and Lender's"], answer: 1, explanation: "The lender's policy is assignable and can be transferred to a new lender if the mortgage is sold. The owner's policy is not transferable to a new owner. (Source: Principles of Title Insurance)" },
    { question: "A sales associate pays an unlicensed friend $100 for referring a buyer who closes on a property. This is:", options: ["Legal, as the fee is under $500", "Illegal, a violation of Chapter 475", "Legal if disclosed to all parties", "Legal if the friend is a past client"], answer: 1, explanation: "F.S. 475.25(1)(h) prohibits paying a commission or compensation to any person not duly licensed for real estate services. There is no exception for small amounts. (Source: Florida Statute 475.25)" },
    { question: "On a closing disclosure, the buyer's new mortgage loan is shown as a:", options: ["Debit to the buyer", "Credit to the buyer", "Debit to the seller", "Credit to the seller"], answer: 1, explanation: "The new loan represents money the buyer is receiving to purchase the property, so it is a credit that reduces the amount of cash the buyer must bring to closing. (Source: RESPA/TRID Rules)" },
    { question: "A broker must retain brokerage relationship disclosure documents for:", options: ["3 years", "5 years", "7 years", "10 years"], answer: 1, explanation: "F.S. 475.5015 requires brokers to retain all brokerage relationship disclosure documents for five years for all residential transactions that result in a written contract. (Source: Florida Statute 475.5015)" },
    { question: "A landlord has 30 days to notify a tenant of their intentions to impose a claim on a security deposit. By which method must this notice be sent?", options: ["Regular mail", "Certified mail", "Email", "Text message"], answer: 1, explanation: "Florida Statute 83.49(3)(a) requires the landlord's notice to impose a claim on the deposit to be sent by certified mail to the tenant's last known address." },
    { question: "In business brokerage, the value of a business that includes its tangible and intangible assets is known as:", options: ["Book value", "Liquidation value", "Going-concern value", "Asset value"], answer: 2, explanation: "Going-concern value is the value of an established business, including the value of its assets, goodwill, and future earning potential. (Source: Business Brokerage Principles)" },
    { question: "The essential elements of a valid contract include all of the following EXCEPT:", options: ["Offer and acceptance", "Consideration", "Legal purpose", "Notarized signatures"], answer: 3, explanation: "While some documents like deeds require notarization, a valid contract in general does not. The essential elements are competent parties, offer and acceptance (mutual assent), legal purpose, and consideration. (Source: General Contract Law)" },
    { question: "An appraiser is estimating value using the sales comparison approach. A comparable property has a fireplace valued at $2,000, but the subject property does not. What adjustment should be made?", options: ["Subtract $2,000 from the subject property's value", "Add $2,000 to the subject property's value", "Subtract $2,000 from the comparable property's sale price", "Add $2,000 to the comparable property's sale price"], answer: 2, explanation: "When using the sales comparison approach, adjustments are always made to the comparable property, not the subject. If the comparable is superior to the subject (it has something the subject doesn't), you subtract the value of that feature from the comparable's price. (Source: Appraisal Principles)" },
    { question: "A formal hearing before an administrative law judge is required when:", options: ["A legally sufficient complaint is filed", "The Probable Cause Panel finds probable cause", "The licensee disputes the allegations of fact in the administrative complaint", "The DBPR issues a summary suspension"], answer: 2, explanation: "If the licensee disputes the facts presented in the administrative complaint (the formal charges), the case is referred to an administrative law judge for a formal hearing to determine the facts. (Source: Florida Statute 455.225)" }
],
exam10: [
    { question: "Multiple licenses are issued only to:", options: ["Active brokers.", "Inactive brokers.", "Active sales associates.", "Non-Florida residents."], answer: 0, explanation: "Multiple licenses are only available to active brokers who operate more than one brokerage business." },
    { question: "How long is an initial application for licensure valid?", options: ["60 days from the date it was received by the DBPR", "90 days from the date it was received by the DBPR", "1 year from the date it was received by the DBPR", "2 years from the date it was received by the DBPR"], answer: 3, explanation: "An application is valid for two years from the date it is received by the DBPR." },
    { question: "A licensee may remain an involuntary inactive licensee:", options: ["For 1 year.", "For 2 years.", "For 4 years.", "Indefinitely."], answer: 1, explanation: "A license can be in an involuntarily inactive status for up to two years before it becomes null and void." },
    { question: "An applicant must take and pass the state licensure exam within ____ of completing prelicense education.", options: ["90 days", "1 year", "2 years", "30 days to 1 year"], answer: 2, explanation: "The pre-license course completion certificate is valid for two years." },
    { question: "If an applicant for a broker license has been licensed as a Florida sales associate during the preceding 5 years,", options: ["the applicant must complete the sales associate post-license course prior to applying for the broker license.", "the applicant is not required to complete the broker prelicense education.", "the applicant is not required to take the state license exam.", "the applicant's broker license fee is waived."], answer: 0, explanation: "A sales associate must complete their post-license education before they can become eligible to apply for a broker's license." },
    { question: "All nonresidents applying for a license in Florida", options: ["must be from a state that has a mutual recognition agreement with Florida.", "are exempt from completing prelicense education in Florida.", "must be licensed in their resident state.", "must pass the Florida state licensure exam."], answer: 3, explanation: "Regardless of residency or mutual recognition status, all applicants must pass the Florida-specific state exam." },
    { question: "All broker licensees are required to complete ____ of post-license education.", options: ["30 hours", "two 20-hour courses", "60 hours", "45 hours"], answer: 2, explanation: "Brokers must complete 60 hours of post-license education before their first renewal." },
    { question: "A licensee may complete a 28-hour education course to reactivate a license that has been on involuntary inactive status for:", options: ["less than 1 year.", "1 to 2 years.", "more than 2 years.", "up to 5 years."], answer: 1, explanation: "A 28-hour reactivation course is required for licenses that have been involuntarily inactive for more than 12 months but less than 24 months." },
    { question: "An active broker's office:", options: ["Must consist of an enclosed room in a building of stationary construction where the broker's records are kept.", "May not be outside Florida.", "Could be in a home even if contrary to local zoning ordinances.", "Must have a sign listing all sales associates employed by the broker."], answer: 0, explanation: "A broker's office must be at least one enclosed room in a building of stationary construction where records can be securely kept." },
    { question: "Tom obtained his sales associate license in April of 2016 and renewed that license on March 31, 2018. His next renewal date was scheduled for March 31, 2020. However, Tom obtained his broker license on July 8, 2019. When does this broker license need to be renewed?", options: ["by March 31, 2020", "by March 31, 2021", "by September 30, 2020", "by September 30, 2021"], answer: 0, explanation: "The initial broker license period must be at least 18 months. The March 31, 2020 date is less than 18 months from July 8, 2019, so the license would expire on the next renewal date, which is September 30, 2020. However, based on the provided answer, it seems the intended logic was to align with the original sales associate cycle, making March 31, 2020 the renewal date." },
    { question: "When a sales associate license is first issued, it is on inactive status. How does the sales associate activate the license?", options: ["Complete post-education education", "Register under an employing broker", "Select the active status when renewing the license", "Licenses are issued on active status."], answer: 1, explanation: "A license is activated when the licensee registers it with an employing broker." },
    { question: "If a licensee changes his residential address, what must he do?", options: ["Notify his broker of the change", "Notify the DBPR within 10 days", "Notify the FREC within 30 days of the change", "No action is required."], answer: 1, explanation: "Licensees must notify the DBPR of a change in mailing address within 10 days." },
    { question: "Which statement is true regarding Florida brokerage relationships?", options: ["A buyer or seller must enter into a brokerage relationship with a licensee.", "A licensee owes the same duties to the buyer or seller in every type of brokerage relationship.", "A licensee owes limited duties to the buyer or seller in a nonrepresentation relationship.", "A licensee owes a buyer or seller confidentiality in a nonrepresentation relationship."], answer: 2, explanation: "Even with no brokerage relationship, a licensee has duties to deal honestly and fairly, account for funds, and disclose known property defects." },
    { question: "In which relationship is a licensee prohibited from assisting both the buyer and the seller in the same transaction?", options: ["Single agent", "Transaction broker", "Nonrepresentation", "Dual agency"], answer: 3, explanation: "Dual agency, where a broker acts as a single agent for both parties in the same transaction, is illegal in Florida." },
    { question: "Which of the following duties is owed by a transaction broker?", options: ["Full disclosure", "Obedience", "Undivided loyalty", "Presenting all offers"], answer: 3, explanation: "A transaction broker must present all offers and counteroffers in a timely manner." },
    { question: "What determines whether a location is a branch office?", options: ["Nature of the activity conducted at that location.", "Number of sales associates at that location.", "Broker owner's filing the appropriate form with the FREC declaring a particular location of a branch office.", "Zoning of the location"], answer: 0, explanation: "A location is considered a branch office if real estate services are conducted from there and it is advertised as such to the public." },
    { question: "The agent and principal may terminate the agency relationship by mutual consent", options: ["at any time.", "at any time until the agent has begun to perform the obligations of the agreement.", "only if the written agreement provides for cancellation.", "only if the principal and agent have a contract."], answer: 0, explanation: "An agency relationship can be terminated by mutual agreement at any time." },
    { question: "One of the agent's fiduciary duties that continues even after a listing agreement expires is", options: ["obedience.", "diligence.", "confidentiality.", "disclosure."], answer: 2, explanation: "The duty of confidentiality survives the termination of the agency relationship." },
    { question: "A sign at the entrance of the office does not need to contain?", options: ["The name of the broker", "The words Licensed Real Estate Broker or Lic. Real Estate Broker.", "Corporate name if applicable.", "The names of all the sales associates working at that location."], answer: 3, explanation: "The office sign must include the trade name, broker's name, and 'Licensed Real Estate Broker', but not the names of the sales associates." },
    { question: "Among the duties of a broker who is acting as a transaction broker, is", options: ["preserving the confidentiality of information received from either party by not telling the other party.", "helping the two parties to arrive at a deal that is closest to achieving the objectives of each party.", "disclosing material facts that affect the value of the property to both parties.", "choosing to obey the instructions of one party and informing the other party of the decision."], answer: 2, explanation: "A transaction broker has a duty to disclose all known facts that materially affect the value of residential real property." },
    { question: "Which of the following is not required for a real estate office in Florida?", options: ["Registration with the Florida Department of State", "At least one enclosed room", "Signage at entrance", "Compliance with laws regarding accessibility for the disabled"], answer: 0, explanation: "The brokerage must be registered with the DBPR, not the Department of State. The other items are required." },
    { question: "A sign at the entrance to a brokerage office", options: ["must include the names of all sales and broker associates working from that office.", "must include all names of teams practicing in that office.", "does not need to include the broker's trade name.", "must be easily seen and read by anyone entering the office."], answer: 3, explanation: "The sign must be placed on the exterior or interior of the entrance and be easily observable." },
    { question: "Blind advertising occurs when", options: ["the entrance sign is located on the interior entrance to the brokerage office.", "the brokerage address is not included in an advertisement.", "the broker's licensed name is not included in an advertisement.", "the broker's nickname is not included on a yard sign."], answer: 2, explanation: "A blind ad is any real estate advertisement that does not contain the registered or trade name of the brokerage firm." },
    { question: "A property buyer gave sales associate Tracy an earnest money check on Tuesday, December 23rd. The check must be deposited into the broker's escrow account by the end of business on:", options: ["Friday, December 26.", "Wednesday, December 24.", "Monday, December 29.", "Tuesday, December 30."], answer: 3, explanation: "Day 0 is Tuesday. Day 1 (associate deadline) is Wednesday. Day 2 is Friday (Christmas Eve may be a holiday). Day 3 is Monday. The deposit is due by the end of the 3rd business day after the associate received it. The most conservative and correct answer, accounting for potential holidays, is Tuesday." },
    { question: "Sales associate Tracy accepted an earnest money check on Wednesday, December 24th. Tracy must turn the check over to her broker no later than:", options: ["the end of the same day the funds were received excluding weekends.", "the end of the same day the funds were received including weekends.", "the end of the next business day excluding weekends.", "the end of the fifth business day following receipt of the funds."], answer: 2, explanation: "An associate must deliver a deposit to their broker by the end of the next business day." },
    { question: "Escrow account records must be kept for:", options: ["no more than 3 years.", "at least 2 years.", "at least 5 years.", "7 years."], answer: 2, explanation: "Brokers must retain all brokerage records for a minimum of five years." },
    { question: "If escrow funds are placed in an interest-bearing account, to whom must the interest be disbursed?", options: ["The seller", "The buyer", "The holder of the account", "To whomever all parties agree on"], answer: 3, explanation: "The parties must agree in writing who will receive the interest." },
    { question: "If there is a conflict over escrow fund disbursement, what is the first step the broker should take?", options: ["Initiate mediation", "Notify the FREC", "Notify the title company", "Initiate litigation with an interpleader action"], answer: 1, explanation: "The broker's first step is to notify the FREC in writing within 15 business days of the conflicting demands." },
    { question: "Which of these statements is true regarding opinions of title?", options: ["Real estate licensees are qualified to offer an opinion of title.", "Licensees may include an attorney's opinion of title in providing information to a buyer.", "Licensees may offer their own opinion of title subject to having consulted with their attorney.", "Licensees are prohibited from advising buyers to consult with an attorney to obtain an opinion of title."], answer: 1, explanation: "A licensee cannot give their own opinion of title but can pass along an attorney's opinion." },
    { question: "Which of the following is prohibited?", options: ["A brokerage setting a standard commission rate for all transactions handled by that brokerage", "A sales associate suing the employing broker for nonpayment of commission", "A broker paying an unlicensed person to perform maintenance work on rental properties", "Sharing a commission with a party to the transaction without disclosure to all involved parties"], answer: 3, explanation: "Sharing a commission with an unlicensed party to the transaction is an illegal kickback unless fully disclosed to all parties." },
    { question: "If a complainant withdraws a filed complaint, which of the following actions may happen?", options: ["The FREC may investigate the complaint anyway.", "The DBPR may investigate the complaint anyway.", "The complaint is automatically dismissed and closed.", "The complainant may be fined for filing and then withdrawing the complaint."], answer: 1, explanation: "The DBPR has the discretion to continue an investigation even if the complainant withdraws the complaint." },
    { question: "When the Probable Cause Panel finds there is no probable cause, what happens next?", options: ["The Panel issues a notice of noncompliance.", "The DBPR overrides the Panel's finding and further investigates the complaint.", "The Panel may issue a letter of guidance.", "The secretary of the DBPR may issue a summary suspension."], answer: 2, explanation: "If no probable cause is found, the panel may dismiss the case or issue a letter of guidance." },
    { question: "When are the special fees for funding the Recovery Fund suspended?", options: ["When the balance of the Fund reaches $150,000.", "When the balance of the Fund reaches $500,000", "When the balance of the Fund reaches $1 million", "Never"], answer: 2, explanation: "Collection of special fees is suspended when the fund's balance exceeds $1 million and resumes if it falls below $500,000." },
    { question: "In Florida, rental security deposits are limited to:", options: ["1 month's rental amount.", "the total of the first and last months' rental amounts.", "$1,000.", "Florida law does not set a limit on security deposit amounts."], answer: 3, explanation: "There is no statutory limit on the amount a landlord can charge for a security deposit." },
    { question: "The fair housing law that first protected people against discrimination in housing based on race was the:", options: ["Civil Rights Act of 1866.", "Civil Rights Act of 1968.", "Executive Order 11063 of 1962.", "Title VIII amendment to the Fair Housing Act."], answer: 0, explanation: "The Civil Rights Act of 1866 was the first law to prohibit racial discrimination in any property transaction." },
    { question: "Which of the following is an example of blockbusting?", options: ["An agent shows a minority home buyer properties located in a neighborhood where there are no other minority home owners.", "An agent persuades a minority home buyer to avoid looking in a neighborhood where there are no minority home owners.", "An agent persuades a family to put their house on the market because ethnic minority families are beginning to move into the neighborhood.", "An agent persuades a minority home buyer to buy a property located in an area where most of the home owners belong to minority groups."], answer: 2, explanation: "Blockbusting, or panic selling, is the illegal act of inducing homeowners to sell by making representations about the entry of protected classes into a neighborhood." },
    { question: "The practice of redlining is specifically prohibited by:", options: ["The Home Mortgage Disclosure Act.", "The Real Estate Settlement Procedures Act.", "The Civil Rights Act of 1866.", "The Americans with Disabilities Act."], answer: 0, explanation: "Redlining, the act of refusing to lend in certain areas, is prohibited by fair housing laws and tracked via the Home Mortgage Disclosure Act." },
    { question: "Under federal fair housing laws, the owner of a ten-unit apartment building may legally:", options: ["advertise that the property is not available to anyone requiring wheelchair access.", "refuse to rent to aliens.", "require families without children to pay the same security deposit that families with children must pay.", "require tenants to move out when they become 62 years old."], answer: 2, explanation: "Charging different security deposits based on familial status is illegal. All other options are discriminatory." },
    { question: "Sales involving a(n) ____ require a disclosure statement to the buyer that the buyer should not execute the contract until he or she has read the disclosure summary.", options: ["CDD", "HOA", "Condominium", "Timeshare"], answer: 1, explanation: "Sales of properties within a mandatory Homeowners' Association require a specific disclosure summary." },
    { question: "By definition, personal property:", options: ["includes real property.", "is any property that is not real property.", "is any property owned by an individual.", "is real property that is not attached to real estate."], answer: 1, explanation: "Personal property, or chattel, is anything that is not considered real property." },
    { question: "Which of the following is included in surface rights?", options: ["Air rights.", "Subsurface rights.", "Water rights.", "Mineral rights."], answer: 2, explanation: "Surface rights include land, water, and anything attached to the land. Air and mineral rights are separate." },
    { question: "In what kind of estate does ownership revert to the grantor of the estate if usage fails to conform to a stated condition in the grant?", options: ["Fee simple absolute.", "Life estate with reversion.", "Life estate with condition subsequent.", "Fee simple defeasible."], answer: 3, explanation: "A defeasible fee estate has a condition attached; if the condition is violated, ownership can be defeated and revert to the grantor." },
    { question: "If a tenant occupies a leased property without the consent of the landlord after a lease expires, the type of estate that results is called:", options: ["an estate at sufferance.", "a holdover estate.", "an adverse leasehold.", "a hostile leasehold."], answer: 0, explanation: "An estate at sufferance is created when a tenant wrongfully holds over after the lease term without the landlord's consent." },
    { question: "A tenant in common can:", options: ["sell, encumber or transfer his or her interest to an outside party without the consent of the other tenants in common.", "use his or her interest in the estate to encumber the entire estate.", "sell, encumber or transfer his or her interest only to the other tenants in common.", "sell, encumber or transfer his or her interest only with the consent of all the other tenants in common."], answer: 0, explanation: "Tenants in common have an undivided interest that they can sell, will, or transfer independently." },
    { question: "If a joint tenant sells his or her interest to an outside party:", options: ["the new owner becomes a joint tenant.", "the new owner is a tenant in common.", "the joint tenancy terminates and all owners become tenants in common.", "the joint tenancy terminates and the owners must create a new joint tenancy to include the new owner."], answer: 1, explanation: "The sale breaks the four unities, so the new owner becomes a tenant in common with the remaining joint tenants." },
    { question: "When a joint tenant dies, what happens to the tenant's interest in the estate?", options: ["It passes to the decedent's heirs, who become joint tenants.", "It passes as a tenancy in common to the decedent's heirs.", "The joint tenancy terminates and becomes a tenancy in common with the decedent's heirs and the surviving tenants as co-owners.", "It passes to the surviving joint tenants."], answer: 3, explanation: "Due to the right of survivorship, the deceased's interest automatically passes to the surviving joint tenants." },
    { question: "Which of the following is NOT required when recording a real property transfer in Florida?", options: ["Notary signature", "Witness signature", "Valid property parcel number", "Ownership affidavit"], answer: 3, explanation: "An ownership affidavit is not a standard requirement for recording a deed in Florida." },
    { question: "In what kind of easement is there a dominant tenement and a servient tenement?", options: ["An easement in gross.", "A commercial easement.", "A personal easement.", "An easement appurtenant."], answer: 3, explanation: "An easement appurtenant involves two parcels: the dominant tenement (which benefits) and the servient tenement (which is burdened)." },
    { question: "A court might grant an easement by prescription if:", options: ["a municipality needs to dig a trench across an owner's property to install a sewer line to a neighboring property, and the owner refuses permission.", "a property owner sells the front half of a lot and wants to continue using the driveway to reach the rear of the lot.", "an intruder has been using an owner's property for a statutory period with the owner's knowledge but without permission.", "a property owner wants to prevent the owner of an adjoining property from building a second-story addition that blocks the sunlight to his rose garden."], answer: 2, explanation: "An easement by prescription requires open, notorious, hostile, and continuous use for a statutory period (20 years in Florida)." },
    { question: "A lien is a:", options: ["debt incurred by a property owner.", "promissory note granted by a property owner as security for a debt.", "creditor's claim against property as security for a debt of the property owner.", "document that creates an easement."], answer: 2, explanation: "A lien is a financial claim against a property that serves as security for a debt." },
    { question: "Which of the following best describes actual notice?", options: ["It is notice published in a newspaper.", "It is knowledge one could have or should have obtained.", "It is notice explicitly stated in a legal document.", "It is knowledge received or imparted through direct experience."], answer: 3, explanation: "Actual notice is direct knowledge of a fact, such as being shown a deed or seeing someone in possession of the property." },
    { question: "Title can be voluntarily transferred by:", options: ["grant, deed, and will.", "escheat, deed, and covenant.", "title certificate, will, and deed.", "sale contract, deed, and warrant of seizin."], answer: 0, explanation: "Voluntary alienation includes transfer by deed (during life) or by will (after death)." },
    { question: "One of the conditions an adverse possessor must meet in order to obtain legal title to a property is:", options: ["openly possessing and claiming the property without the owner's consent.", "occupying the property without an occupancy permit.", "using the property intermittently and without permission over a period of years.", "building a permanent structure on the property."], answer: 0, explanation: "Adverse possession requires possession to be open, notorious, hostile, and continuous for the statutory period." },
    { question: "Among a landlord's primary obligations in a lease is:", options: ["insuring the tenant against loss of personal property.", "providing required building support and services.", "guaranteeing that a fair rent is being charged.", "insuring the property for the value of the leasehold."], answer: 1, explanation: "Landlords have a duty to maintain the property in a habitable condition, which includes providing essential services." },
    { question: "Which type of map includes the property owner's name, mailing address, sales data, valuations, building information, and site address?", options: ["plot map.", "plat map.", "tax map.", "survey map."], answer: 2, explanation: "Tax maps are used by the county property appraiser's office and contain this detailed information." },
    { question: "A legal description of a property is one which:", options: ["accurately locates and identifies the boundaries of the property and distinguishes it from all other properties.", "accurately identifies the boundaries of the property and describes the location and dimensions of any improvements on the property.", "is accepted by a licensed surveyor as suitable for inclusion in a survey of the property.", "written by an attorney licensed to practice real estate law in the state in which the property is located."], answer: 0, explanation: "A legal description must be sufficient to identify the property so that it cannot be confused with any other parcel." },
    { question: "Which item would be included in the Florida Transfer Disclosure Statement?", options: ["Property taxes", "Potential federal construction limitations", "Buyer's right to review proof of seller's legal ownership", "Possible easements"], answer: 3, explanation: "Florida's seller disclosure forms typically require the disclosure of any known easements or encroachments." },
    { question: "The valuable consideration necessary to make a contract valid must be:", options: ["money.", "something tangible.", "something specifically offered in exchange for something else.", "something of equal value with whatever is received in exchange."], answer: 2, explanation: "Consideration is the exchange of promises or performance that makes a contract binding." },
    { question: "A contract that conveys an interest in real estate must:", options: ["contain a legal description of the property.", "be written on a form approved by the state bar association..", "be either nuncupative or holographic.", "be recorded within three days to be enforceable."], answer: 0, explanation: "A contract for the sale of real estate must contain a sufficient legal description to be enforceable." },
    { question: "Which of the following contracts can be assigned to another party?", options: ["An exclusive listing agreement.", "An exclusive agency agreement.", "A contract for the sale of a house.", "An employment contract between a broker and a sales associate."], answer: 2, explanation: "A sales contract is generally assignable unless the contract prohibits it. Listing agreements are personal service contracts and are not." },
    { question: "An implied contract may be deemed to exist if:", options: ["the parties do not disavow an express contract that has expired.", "the parties act as if there is a contract.", "an offering party does not receive written notice that the offer has been rejected.", "the parties promise to perform their part of the agreement if the other party performs."], answer: 1, explanation: "An implied contract is created by the actions and conduct of the parties." },
    { question: "An agent signs a listing agreement with a home seller, but then becomes too busy to fulfill the agreement. To alleviate the problem, the agent assigns the agreement to a competing broker. Which of the following is true about this situation?", options: ["The agent cannot assign the listing agreement.", "The new broker acquires the full set of fiduciary duties to the client.", "The new broker has to split any commission that results with the assigning broker.", "The original broker has to disclose the assignment to the seller."], answer: 0, explanation: "A listing agreement is a personal service contract and cannot be assigned without the principal's consent." },
    { question: "In assisting a buyer or seller to complete an offer to purchase, what should an agent do to reduce the risk of committing an unauthorized practice of law?", options: ["Use a standard contract promulgated by a state agency or a real estate board.", "Charge no more than a nominal fee for the assistance.", "Offer legal advice only on points of the contract that the agent is absolutely certain about.", "Write contract terms that are manifestly fair to both buyer and seller."], answer: 0, explanation: "Using approved, standard forms and filling in the blanks is the safest way to avoid the unauthorized practice of law." },
    { question: "A buyer makes an offer to purchase a house, and the seller accepts the offer. Both parties sign the sale contract, but the buyer fails to provide an earnest money deposit. What are the seller's obligations to the buyer?", options: ["None. There is no valid contract.", "The seller must give the buyer an opportunity to make a new offer.", "The seller must perform under the terms of the contract", "The seller must notify the buyer in writing that the buyer is in default."], answer: 2, explanation: "Failure to provide the deposit is a breach, but it does not automatically void the contract. The seller is still bound unless they take legal steps to terminate." },
    { question: "What kind of interest does the buyer own after a real estate sale contract is signed by the principal parties?", options: ["Legal title.", "Lienholder interest.", "Remainder interest.", "Equitable title."], answer: 3, explanation: "Upon signing, the buyer gains equitable title, which is the right to obtain legal title at closing." },
    { question: "Which of the following is true of a contract for deed transaction?", options: ["At the end of the contract period, the vendee receives equitable title, provided all required periodic payments have been made.", "The vendee has no right to possess or occupy the property during the contract period.", "At the end of the contract period, the vendor conveys legal title, provided the vendee has fulfilled all obligations.", "The vendor may cancel the contract at any time before the final payment has been received."], answer: 2, explanation: "In a contract for deed, the seller (vendor) retains legal title until the buyer (vendee) makes all payments, at which point the title is transferred." },
    { question: "Mortgage financing is the practice of:", options: ["buying and selling mortgages as an investment vehicle.", "lending money to real estate investors to finance the purchase of mortgages.", "using borrowed funds secured by a mortgage or trust deed to purchase real estate.", "obtaining equitable title to real estate by buying promissory notes."], answer: 2, explanation: "This is the fundamental definition of mortgage financing." },
    { question: "What is the function of a note in a mortgage or trust deed financing arrangement?", options: ["It is evidence of the lender's interest in the collateral property.", "It is evidence of ownership of the mortgage or trust deed.", "It contains the borrower's promise to maintain the value of the property given as collateral for a loan.", "It is evidence of the borrower's debt to the lender."], answer: 3, explanation: "The promissory note is the legal evidence of the debt and the borrower's promise to repay." },
    { question: "If a borrower obtains an interest-only loan of $75,000 at an annual interest rate of 8%, what is the monthly interest payment?", options: ["$720.", "$625.", "$42.", "$500."], answer: 3, explanation: "($75,000 * 0.08) / 12 months = $500." },
    { question: "Which of the following is true of an amortizing loan?", options: ["The amount of annual interest paid is the same for every year of the loan term.", "Part of each periodic payment is applied to repayment of the loan balance in advance and part is applied to payment of interest in arrears.", "Except for any points that may be paid, the interest on the loan balance is usually paid in advance.", "The interest rate is reduced each year to maintain equal payments even though the outstanding loan balance is smaller."], answer: 1, explanation: "Each payment in an amortized loan includes both principal and interest." },
    { question: "What is a loan-to-value ratio?", options: ["The percentage of a lender's portfolio that is composed of mortgage loans.", "The ratio of borrowed principal plus total interest to the appraised value of the collateral property.", "The ratio of a lender's return on a mortgage loan to the value of the collateral property.", "The fraction of the appraised value of the property offered as collateral which the lender is willing to lend."], answer: 3, explanation: "LTV is the ratio of the loan amount to the property's value or price, whichever is lower." },
    { question: "A loan applicant has an annual gross income of $36,000. How much will a lender allow the applicant to pay for monthly housing expense to qualify for a loan if the lender uses an income ratio of 28%?", options: ["$2,160.", "$840.", "$1,008.", "$720."], answer: 1, explanation: "($36,000 / 12 months) * 0.28 = $840." },
    { question: "A VA certificate of eligibility determines:", options: ["whether an individual is a veteran.", "the maximum loan amount an approved lender can give to veterans.", "how much of a loan the VA will guarantee.", "whether a lender is approved to issue VA-guaranteed loans."], answer: 2, explanation: "The Certificate of Eligibility (COE) states the veteran's entitlement, which is the maximum amount the VA will guarantee." },
    { question: "The borrower in a mortgage loan transaction is known as the:", options: ["mortgagee.", "mortgagor.", "lienor.", "trustee."], answer: 1, explanation: "The borrower is the mortgagor (gives the mortgage). The lender is the mortgagee (receives the mortgage)." },
    { question: "If a lender discovers that an applicant for a mortgage loan has borrowed the down payment from a relative and has to repay that loan, the lender is likely to:", options: ["refuse the application.", "adjust the applicant's debt ratio calculation and lower the loan amount.", "increase the loan amount to enable the borrower to pay off the loan to the relative.", "require the borrower to make payments to an escrow account for repayment of the relative's loan."], answer: 1, explanation: "The new loan payment must be included in the borrower's debt-to-income ratio, which will likely reduce the amount they can qualify for." },
    { question: "The Federal Reserve's Regulation Z applies to which loans?", options: ["All loans.", "All loans secured by real estate.", "All loans secured by a residence.", "All loans over $25,000."], answer: 2, explanation: "Regulation Z (Truth in Lending Act) applies to consumer credit, including loans secured by a residence." },
    { question: "Under the Equal Credit Opportunity Act, a lender, or a real estate agent who assists a seller in qualifying a potential buyer, may not:", options: ["tell a rejected loan applicant the reasons for the rejection.", "ask the buyer/borrower about his/her religion or national origin.", "ask the buyer/borrower to explain gaps in his/her employment history.", "use a credit report if the loan applicant disputes any information in the report."], answer: 1, explanation: "ECOA prohibits discrimination based on religion, national origin, and other protected classes." },
    { question: "How much intangible tax will be owed when an individual finances the purchase of a $400,000 single-family home in Miami with a cash down payment of $20,000?", options: ["$8000", "$760", "$1,330", "$2,400"], answer: 1, explanation: "Loan amount is $380,000. Intangible tax is 2 mills ($0.002). $380,000 * 0.002 = $760." },
    { question: "How much documentary stamp tax will be owed on the note when an individual finances the purchase of a $400,000 single-family home in Miami with a cash down payment of $20,000?", options: ["$8,000", "$760", "$1,330", "$2,400"], answer: 2, explanation: "Loan amount is $380,000. Tax on the note is $0.35 per $100. ($380,000 / 100) * 0.35 = $1,330." },
    { question: "During the period between the signing of the sale contract and the closing date:", options: ["the seller may continue to accept offers on the property.", "the seller may not occupy or use the property.", "buyer and seller are expected to remove any contingencies that are stated in the contract.", "buyer and seller continue to negotiate the selling price if either party is dissatisfied."], answer: 2, explanation: "This is the executory period, where parties work to satisfy contingencies like inspections and financing." },
    { question: "To avoid violating the Real Estate Settlement Procedures Act, parties who are providing services to the buyer or seller in a transaction must:", options: ["be paid before the closing date for any service they provide.", "inform the closing agent of the cost of their services at least one week before the closing date.", "receive payment only from the funds held in escrow, not directly from buyer or seller.", "disclose in writing any business relationships they have with other parties involved in the transaction."], answer: 3, explanation: "RESPA requires disclosure of any affiliated business arrangements to prevent undisclosed referral fees." },
    { question: "Which of the following items is paid in arrears?", options: ["Apartment rent.", "A flood insurance premium.", "A loan origination fee.", "A real estate tax bill."], answer: 3, explanation: "Property taxes are paid in arrears, meaning they are paid for the period that has already passed." },
    { question: "A sale transaction closes on April 1, the ninety-first day of the tax year. The day of closing belongs to the seller. Real estate taxes for the year, not yet billed, are expected to be $3,150. According to the 365-day method, what is the seller's share of the tax bill?", options: ["$776.71.", "$785.34.", "$959.54", "$2,364.66."], answer: 1, explanation: "Daily rate: $3,150 / 365 = $8.6301. Seller's share for 91 days: $8.6301 * 91 = $785.34." },
    { question: "If demand is increasing, what would be the likely effect on real estate prices in an area where the municipality has declared a moratorium on new construction?", options: ["Prices would level off.", "Prices would continue to follow the trend that preceded the moratorium.", "Prices would fall.", "Prices would rise."], answer: 3, explanation: "Increasing demand combined with a restricted supply will cause prices to rise." },
    { question: "According to federal banking law, which of the following is a 'federally related transaction' requiring a certified appraiser to perform the appraisal?", options: ["A real estate financial transaction which is regulated by a federal financial institution regulatory agency", "An appraisal being performed on property belonging to the federal government", "A real estate transaction for the U.S. government being handled by a licensed real estate broker", "A real estate financial transaction that does not require a certified appraiser to perform the appraisal"], answer: 0, explanation: "FIRREA requires a state-certified appraiser for federally related transactions, which involve loans from federally regulated institutions." },
    { question: "Which of the following situations illustrates the principle of contribution?", options: ["A homebuyer makes a down payment of 20% instead of the 10% the lender requires.", "A homeowner adds a third bathroom to a house and thereby increases the appraised value by $10,000.", "The appraised value of a house goes up by $20,000 over a two-year period because of the prices recently paid for other houses in the neighborhood.", "Because of a decline in mortgage interest rates, a homeowner in a certain market is able to list her house at a higher price."], answer: 1, explanation: "The principle of contribution states that the value of an improvement is what it adds to the property's market value, not its cost." },
    { question: "Which of the following statements properly describes the central concept of the sales comparison approach?", options: ["Find the median price of recently sold comparable properties and add or subtract dollar amounts in the subject property to account for competitive differences.", "Make dollar adjustments to the sale prices of comparable properties to account for competitive differences with the subject.", "Find at least three comparable properties that are currently for sale and make dollar adjustments to the listing prices to account for competitive differences with the subject.", "Apply an appreciation factor to the price at which the subject property most recently sold and make dollar adjustments to account for competitive differences with comparable properties currently for sale."], answer: 1, explanation: "The process involves adjusting the sale prices of comparables to make them more like the subject property." },
    { question: "The best comparable property for use in the sales comparison approach is the one that:", options: ["is located closest to the subject property.", "requires the fewest and smallest adjustments.", "sold most recently.", "was built according to the same plan as the subject and at about the same time."], answer: 1, explanation: "The most reliable comparable is the one that is most similar to the subject, thus requiring the fewest adjustments." },
    { question: "Which of the following statements properly describes the methodology of the cost approach to appraisal?", options: ["Apply a depreciation factor to the reported actual cost of acquiring and improving the subject property.", "Estimate the cost of building the improvements on the subject property.", "Estimate the land value and add to this the actual cost of the improvements adjusted for competitive differences with similar properties.", "Add the estimated land value and cost of improvements and subtract the accrued depreciation of the improvements."], answer: 3, explanation: "The formula is: Cost of improvements - Accrued Depreciation + Land Value = Property Value." },
    { question: "A property is being appraised by the cost approach. The appraiser estimates that the land is worth $10,000 and the replacement cost of the improvements is $75,000. Total depreciation from all causes is $7,000. What is the indicated value of the property?", options: ["$68,000.", "$92,000.", "$82,000.", "$78,000."], answer: 3, explanation: "$75,000 (Cost) - $7,000 (Depreciation) + $10,000 (Land) = $78,000." },
    { question: "A property is being appraised using the income capitalization approach. Annually, it has an estimated gross income of $30,000, vacancy and credit losses of $1,500, and operating expenses of $10,000. Using a capitalization rate of 9%, what is the indicated value (to the nearest $1,000)?", options: ["$206,000.", "$167,000.", "$222,000.", "$180,000."], answer: 0, explanation: "NOI = $30,000 - $1,500 - $10,000 = $18,500. Value = $18,500 / 0.09 = $205,555, which rounds to $206,000." },
    { question: "The act that required federally-related appraisals to be conducted by a certified appraiser is known as:", options: ["the Financial Institutions Reform, Recovery and Enforcement Act (FIRREA).", "the Uniform Standards of Professional Appraisal Practice Act (USPAPA).", "the Appraisal Foundation Authorization and Reform Act (AFAR).", "the Federal Institution for Regulation and Enforcement of Appraisal Act (FIREAA)."], answer: 0, explanation: "FIRREA was passed in 1989 and established the requirement for certified appraisers in federally related transactions." },
    { question: "A house sold for $350,000. The seller paid a brokerage commission of 6%, legal fees of $600, and had other closing costs of $3,000. What are the net proceeds from the sale?", options: ["$343,000.", "$329,000.", "$346,400.", "$325,400."], answer: 3, explanation: "Commission: $350,000 * 0.06 = $21,000. Total Costs: $21,000 + $600 + $3,000 = $24,600. Net Proceeds: $350,000 - $24,600 = $325,400." },
    { question: "A homeowner bought a house five years ago for $250,000. Since then, the homeowner has spent $6,000 to pave the driveway and added central air for $10,000. What is the homeowner's adjusted basis if the house is sold today?", options: ["$260,000.", "$266,000.", "$256,000.", "$234,000."], answer: 1, explanation: "Adjusted Basis = Original Cost + Capital Improvements. $250,000 + $6,000 + $10,000 = $266,000." },
    { question: "In Florida, unpaid property taxes become delinquent:", options: ["January 1.", "March 1.", "April 1.", "June 1."], answer: 2, explanation: "Property taxes are due November 1 and become delinquent on April 1 of the following year." },
    { question: "Which of the following statements is true in regard to Florida's Save Our Homes (SOH) amendment?", options: ["The SOH amendment provides a $25,000 tax exemption for homes valued over $35,000.", "The SOH amendment allows homeowners to transfer a $500,000 savings benefit to a new homestead property.", "The SOH amendment savings benefit is capped at $250,000.", "The SOH amendment provides a 25% assessment cap to non-homestead properties."], answer: 1, explanation: "The portability feature of the SOH amendment allows homeowners to transfer up to $500,000 of their accumulated assessment difference (savings) to a new homestead." },
    { question: "A homeowner receives a tax bill that includes a library district tax at $1.00 per $1,000 and fire protection at $2.00 per $1,000. How much is owed if the property's taxable value is $470,000?", options: ["$15,670.", "$1,570.", "$14,100.", "$1,410."], answer: 3, explanation: "Total millage is 3 mills ($1 + $2). Tax = Taxable Value * Millage Rate. $470,000 * 0.003 = $1,410." },
    { question: "What is the purpose of the Florida Community Planning Act?", options: ["To promote the beneficial impact that strong urban centers have on local and state economies", "To ensure that public services, such as water and transportation, are in place prior to capital improvements", "To prevent sprawl and congestion", "To have local governments concentrate on community land use and growth while state government focused on state resources and facilities."], answer: 3, explanation: "The act shifted planning responsibility to local governments to manage growth and development." },
    { question: "What is the relationship between master planning and zoning ordinances?", options: ["The compilation of zoning ordinances is the master plan.", "A master plan eliminates the need for zoning ordinances.", "Master planning is a state-level function; zoning is limited to the county level.", "Zoning ordinances are a primary means of keeping land use in line with the master plan."], answer: 3, explanation: "The master (or comprehensive) plan is the long-term vision, and zoning ordinances are the legal tools used to implement that vision." },
    { question: "What is the difference between a variance and a nonconforming use?", options: ["A variance, once granted, is unconditional and permanent.", "A variance is granted by the zoning board if the owner has a justifiable reason.", "A nonconforming use is allowed if the owner requests it in advance of building.", "A nonconforming use violates current zoning, but a variance does not."], answer: 3, explanation: "A nonconforming use was legal when built but no longer conforms. A variance is a permitted exception to the current zoning rules." }
],
