       exam6: [
    { question: "Which valuation approach is most appropriate for a church or school?", options: ["Cost approach", "Income approach", "Sales comparison approach", "Capitalization approach"], answer: 0, explanation: "Special-purpose properties like churches and schools are best valued using the cost approach." },
    { question: "The principle of substitution states that:", options: ["A buyer will not pay more for a property than the cost of an equally desirable substitute.", "Property value is based on the cost of replacement.", "Properties decrease in value over time due to depreciation.", "Market value always equals assessed value."], answer: 0, explanation: "Substitution underpins the sales comparison approach — buyers choose the least costly alternative." },
    { question: "Which type of depreciation is incurable?", options: ["Functional obsolescence", "Physical deterioration", "External obsolescence", "Deferred maintenance"], answer: 2, explanation: "External obsolescence is caused by outside factors (like nearby land use) and is not curable." },
    { question: "In the sales comparison approach, adjustments are made to:", options: ["The subject property", "The comparable properties", "Both subject and comparable", "Neither"], answer: 1, explanation: "Adjustments are always made to comparable sales, never to the subject." },
    { question: "The formula for capitalization rate is:", options: ["Net operating income ÷ Value", "Value ÷ Net operating income", "Gross income ÷ Value", "Value ÷ Gross income"], answer: 0, explanation: "Capitalization rate = NOI ÷ Value." },
    { question: "Reproduction cost differs from replacement cost because it:", options: ["Uses different depreciation methods", "Estimates cost of exact replica", "Excludes land value", "Applies to income-producing property only"], answer: 1, explanation: "Reproduction = exact duplicate; replacement = same utility." },
    { question: "The sales comparison approach relies heavily on:", options: ["Historical construction costs", "Recent comparable sales", "Investor expectations", "Tax assessments"], answer: 1, explanation: "It compares the subject property with recent, similar sales." },
    { question: "Highest and best use is defined as:", options: ["Any legally permissible use", "The use that generates the most income", "The most profitable and legal use", "The use chosen by the owner"], answer: 2, explanation: "Highest and best use must be legal, possible, and maximize return." },
    { question: "Gross Rent Multiplier (GRM) is best used for:", options: ["Owner-occupied homes", "Single-family rentals", "Industrial warehouses", "Special-purpose property"], answer: 1, explanation: "GRM is a shortcut method for small rental properties." },
    { question: "What is functional obsolescence?", options: ["Wear and tear from neglect", "Loss of value from outdated design/features", "Value lost from outside influences", "Deduction for land use restrictions"], answer: 1, explanation: "Functional obsolescence arises from design flaws or outdated features." },
    { question: "Which type of depreciation can usually be corrected at a reasonable cost?", options: ["External obsolescence", "Functional obsolescence", "Economic obsolescence", "Incurable physical deterioration"], answer: 1, explanation: "Functional obsolescence can sometimes be cured (e.g., updating bathrooms)." },
    { question: "The cost approach is most reliable when:", options: ["The property generates income", "Land values are hard to determine", "The property is new", "Many comparable sales exist"], answer: 2, explanation: "New properties are best valued by the cost approach." },
    { question: "Economic obsolescence is also called:", options: ["External obsolescence", "Functional obsolescence", "Physical deterioration", "Replacement depreciation"], answer: 0, explanation: "Both mean value loss from external factors." },
    { question: "When computing NOI, which is deducted?", options: ["Debt service", "Depreciation", "Operating expenses", "Income taxes"], answer: 2, explanation: "Only operating expenses are deducted before arriving at NOI." },
    { question: "Which principle supports the idea that adding too much to a property may decrease its value?", options: ["Conformity", "Contribution", "Substitution", "Anticipation"], answer: 1, explanation: "Principle of contribution measures value added by an improvement." },
    { question: "Assemblage refers to:", options: ["Splitting land into smaller parcels", "Combining parcels for increased value", "Government land seizure", "The sale of development rights"], answer: 1, explanation: "Combining parcels for higher value is assemblage." },
    { question: "Regression occurs when:", options: ["A superior property’s value decreases due to nearby lesser properties", "Land value exceeds improvement value", "Property demand increases with lower supply", "Rent controls are imposed"], answer: 0, explanation: "Regression is value loss from surrounding lower-quality properties." },
    { question: "The income approach is best for:", options: ["New homes", "Vacant land", "Income-producing property", "Special-purpose buildings"], answer: 2, explanation: "It focuses on rental income potential." },
    { question: "Effective age of a property is:", options: ["Actual age of the building", "Age assigned based on condition and utility", "Age when depreciation stops", "Age of the land itself"], answer: 1, explanation: "Effective age reflects condition, not calendar years." },
    { question: "The principle of anticipation holds that:", options: ["Value is based on expected future benefits", "Property values always increase", "Future costs are irrelevant", "Buyers act irrationally"], answer: 0, explanation: "Value is tied to future benefits expected from the property." },
    { question: "A broker must give a copy of the listing agreement to the owner:", options: ["Within 48 hours", "Immediately upon signing", "Within 7 days", "Only upon request"], answer: 1, explanation: "Florida law requires immediate delivery of listing agreements when signed." },
    { question: "Which type of listing allows the seller to list with multiple brokers?", options: ["Exclusive right of sale", "Exclusive agency", "Open listing", "Net listing"], answer: 2, explanation: "Open listings allow multiple brokers; only the procuring cause gets paid." },
    { question: "A broker is guaranteed a commission if the property sells during the listing term under:", options: ["Exclusive right of sale listing", "Exclusive agency listing", "Open listing", "Net listing"], answer: 0, explanation: "In an exclusive right of sale, the broker gets paid regardless of who finds the buyer." },
    { question: "A net listing is legal in Florida only if:", options: ["Both parties agree in writing", "It is properly disclosed and not disadvantageous to the seller", "The buyer also signs approval", "It is filed with FREC"], answer: 1, explanation: "Net listings are legal but risky — disclosure and fairness are required." },
    { question: "A broker is the “procuring cause” of a sale if they:", options: ["Conduct the closing", "Introduce the buyer and seller without interruption in negotiations", "Hold the buyer’s escrow funds", "Draft the purchase contract"], answer: 1, explanation: "Procuring cause means the broker’s efforts caused the uninterrupted chain of events leading to sale." },
    { question: "A broker who misrepresents property in a listing can be charged with:", options: ["Puffing", "Fraud", "Undue influence", "Procuring cause"], answer: 1, explanation: "Misrepresentation of material facts is fraud, while puffing is opinion." },
    { question: "The most common residential listing in Florida is:", options: ["Open listing", "Exclusive agency listing", "Exclusive right of sale listing", "Net listing"], answer: 2, explanation: "Exclusive right of sale listings are most common, giving maximum protection to brokers." },
    { question: "Which listing type could result in no commission if the owner sells the property themselves?", options: ["Exclusive right of sale", "Exclusive agency", "Open listing", "Both B and C"], answer: 3, explanation: "In exclusive agency and open listings, owner sales can eliminate broker commission." },
    { question: "The MLS (Multiple Listing Service) primarily benefits:", options: ["Only sellers", "Only brokers", "Both buyers and sellers", "Only buyers"], answer: 2, explanation: "MLS increases market exposure for sellers and access to inventory for buyers." },
    { question: "Which clause in a listing protects a broker’s commission if a buyer they introduced later purchases the property after the listing expires?", options: ["Arbitration clause", "Net clause", "Protection period clause", "Escrow clause"], answer: 2, explanation: "The protection period clause safeguards broker commission if the deal closes shortly after expiration." },
    { question: "Which is required for all listing agreements in Florida?", options: ["Expiration date", "Witness signatures", "Recording in county records", "MLS submission"], answer: 0, explanation: "Florida law requires all listing agreements to include a definite expiration date." },
    { question: "A broker advertising “Best home in town!” is guilty of:", options: ["Fraud", "Puffing", "Misrepresentation", "Steering"], answer: 1, explanation: "Puffing is exaggerated opinion, not illegal misrepresentation." },
    { question: "A broker promising a guaranteed sale at a set price if they cannot sell within a time frame must:", options: ["File with FREC", "Put guarantee in writing and buy property if not sold", "Get buyer’s approval", "Disclose guarantee in MLS"], answer: 1, explanation: "Guarantees must be in writing, and the broker must honor by buying at the stated price." },
    { question: "If two brokers claim to be procuring cause in a sale, the dispute is settled by:", options: ["The seller", "Arbitration or court", "FREC disciplinary action", "MLS committee"], answer: 1, explanation: "Procuring cause disputes are handled via arbitration or civil court." },
    { question: "Which listing gives the least protection to a broker?", options: ["Exclusive right of sale", "Exclusive agency", "Open listing", "Net listing"], answer: 2, explanation: "Open listings leave brokers at risk of no compensation if another broker or seller closes the deal." },
    { question: "If a broker accepts a listing with a discriminatory restriction, they must:", options: ["Notify FREC", "Follow seller’s instructions", "Refuse the listing", "Advertise as agreed"], answer: 2, explanation: "Fair Housing laws prohibit discriminatory listings; brokers must refuse them." },
    { question: "When must a broker present an oral offer to the seller?", options: ["Only if in writing", "Only if the offer is close to list price", "Immediately and in full", "Only with earnest money deposit"], answer: 2, explanation: "All offers, oral or written, must be promptly presented." },
    { question: "A broker advertising a listed property without the owner’s permission is guilty of:", options: ["Puffing", "False advertising", "Unauthorized practice", "Steering"], answer: 1, explanation: "Owner consent is required for advertising; otherwise it’s false/misleading." },
    { question: "A broker must retain listing records for how long?", options: ["6 months", "1 year", "2 years", "5 years"], answer: 3, explanation: "Florida law requires brokers to keep records for 5 years." },
    { question: "The safest way to determine a listing price is:", options: ["Seller’s preference", "CMA (Comparative Market Analysis)", "Broker’s opinion", "County appraisal"], answer: 1, explanation: "A CMA provides sellers with realistic market value estimates." },
    { question: "A valid contract requires all of the following EXCEPT:", options: ["Offer and acceptance", "Consideration", "Competent parties", "Witness signatures"], answer: 3, explanation: "Witnesses are not required for validity; the essentials are offer, acceptance, consideration, legal purpose, and competent parties." },
    { question: "What type of contract is created when one party makes a promise in exchange for another party’s performance?", options: ["Bilateral", "Unilateral", "Executory", "Implied"], answer: 1, explanation: "Unilateral contracts involve one party making a promise contingent on performance (e.g., option contracts)." },
    { question: "A real estate sales contract is classified as:", options: ["Unilateral, executed", "Bilateral, executory", "Unilateral, executory", "Bilateral, executed"], answer: 1, explanation: "Both parties make promises (bilateral), and performance is pending until closing (executory)." },
    { question: "What is the statute of limitations for written contracts in Florida?", options: ["2 years", "4 years", "5 years", "20 years"], answer: 2, explanation: "Written contracts in Florida have a 5-year statute of limitations." },
    { question: "Which of the following contracts must be in writing to be enforceable under the Statute of Frauds?", options: ["Lease for 6 months", "Purchase and sale agreement", "Brokerage listing agreement", "Oral agreement to purchase land"], answer: 1, explanation: "Real estate sales contracts must be in writing under the Statute of Frauds." },
    { question: "An option contract is:", options: ["Bilateral and binding on both parties", "Unilateral and binding only on the seller", "Unilateral and binding only on the optionor", "Bilateral and binding on the buyer"], answer: 2, explanation: "The optionor (seller) must sell if exercised; the optionee (buyer) has the choice." },
    { question: "What is an executory contract?", options: ["One that has been fully performed", "One that is missing an essential element", "One that is still in the process of being performed", "One that is illegal"], answer: 2, explanation: "Executory = not yet fully performed; executed = completed." },
    { question: "A contract signed by a minor is:", options: ["Valid", "Voidable", "Void", "Enforceable only if witnessed"], answer: 1, explanation: "A minor may void the contract, making it voidable." },
    { question: "What is the legal effect of a contract with an illegal purpose?", options: ["Void", "Voidable", "Enforceable", "Executory"], answer: 0, explanation: "A contract with an illegal purpose is void from inception." },
    { question: "Specific performance is a legal remedy that:", options: ["Cancels the contract", "Awards money damages", "Requires the party to perform as agreed", "Allows the contract to expire"], answer: 2, explanation: "Specific performance forces parties to fulfill contractual obligations." },
    { question: "Liquidated damages in a real estate sales contract usually refer to:", options: ["Court-ordered compensation", "The earnest money deposit", "Commission split", "Title insurance"], answer: 1, explanation: "Earnest money is often the agreed liquidated damages if the buyer defaults." },
    { question: "Which type of listing agreement must be in writing to be enforceable?", options: ["Exclusive right of sale", "Exclusive agency", "Net listing", "All of the above"], answer: 3, explanation: "All listing agreements must be written to be enforceable in Florida." },
    { question: "Which of the following would terminate a contract by operation of law?", options: ["Mutual agreement", "Bankruptcy of a party", "Expiration date", "Novation"], answer: 1, explanation: "Bankruptcy or death of a party can terminate a contract by law." },
    { question: "A buyer makes a counteroffer to a seller. What happens to the original offer?", options: ["It remains valid until accepted", "It becomes a backup contract", "It is terminated", "It is suspended"], answer: 2, explanation: "A counteroffer legally rejects and terminates the original offer." },
    { question: "A novation is:", options: ["Transfer of contract rights to another party", "Substitution of a new contract for the old one", "Breach of contract", "Assignment of a lease"], answer: 1, explanation: "Novation replaces an old contract with a new one, releasing liability." },
    { question: "An oral lease for one year is:", options: ["Void", "Voidable", "Valid and enforceable", "Unenforceable"], answer: 2, explanation: "Leases of one year or less may be oral and still enforceable." },
    { question: "What is mutual rescission?", options: ["One party canceling without consent", "The court voiding the contract", "Both parties agreeing to cancel", "The buyer backing out before acceptance"], answer: 2, explanation: "Mutual rescission = both parties cancel and are released from obligations." },
    { question: "If a seller accepts an offer but changes the closing date, this is:", options: ["Acceptance", "A counteroffer", "Specific performance", "Novation"], answer: 1, explanation: "Any change to an offer is a counteroffer." },
    { question: "An earnest money deposit is required to make a contract:", options: ["Valid", "Void", "Enforceable", "Not required for validity"], answer: 3, explanation: "Earnest money is not required; consideration can be other value." },
    { question: "What is constructive notice of a contract?", options: ["Oral disclosure to all parties", "Physical possession of property", "Recording in the public records", "Witness acknowledgment"], answer: 2, explanation: "Recording in public records provides constructive notice." },
    { question: "A conventional loan is one that is:", options: ["Guaranteed by VA", "Insured by FHA", "Not insured or guaranteed by the government", "Always assumable"], answer: 2, explanation: "Conventional loans are not backed by government insurance or guarantees." },
    { question: "The FHA insures loans to protect:", options: ["The borrower", "The seller", "The lender", "The mortgage broker"], answer: 2, explanation: "FHA insurance protects lenders against borrower default." },
    { question: "Which entity purchases mortgages in the secondary market?", options: ["HUD", "Ginnie Mae", "Fannie Mae", "VA"], answer: 2, explanation: "Fannie Mae buys and sells mortgages in the secondary market." },
    { question: "The VA guarantees loans made to:", options: ["All U.S. citizens", "Veterans and eligible service members", "First-time homebuyers only", "Low-income households"], answer: 1, explanation: "The VA guarantees part of loans for veterans, reservists, and eligible service members." },
    { question: "A partially amortized loan that ends with a final large payment is called a:", options: ["Fully amortized loan", "Straight-term loan", "Balloon payment loan", "Adjustable-rate loan"], answer: 2, explanation: "Balloon loans require a lump sum payment at the end." },
    { question: "A mortgage is best defined as:", options: ["A promissory note", "A lien on property securing the note", "The loan itself", "A deed transferring ownership"], answer: 1, explanation: "The mortgage is the security instrument (lien); the note is the promise to pay." },
    { question: "In a lien theory state like Florida, the borrower:", options: ["Gives title to the lender until paid", "Retains title, lender holds lien", "Has no ownership rights", "Must use a land contract"], answer: 1, explanation: "Florida is a lien theory state; borrower holds title while lender has a lien." },
    { question: "The document that actually evidences the debt is:", options: ["Mortgage", "Promissory note", "Deed", "Title"], answer: 1, explanation: "The promissory note is the borrower’s promise to repay." },
    { question: "A mortgage clause that allows the lender to call the loan due upon sale is called:", options: ["Acceleration clause", "Alienation clause", "Defeasance clause", "Escalation clause"], answer: 1, explanation: "The alienation (due-on-sale) clause requires full repayment upon transfer." },
    { question: "Which loan program requires no down payment for eligible borrowers?", options: ["FHA", "VA", "Conventional", "Adjustable-rate"], answer: 1, explanation: "VA loans often require no down payment." },
    { question: "A lender charging interest above the legal limit is guilty of:", options: ["Subordination", "Usury", "Escrow fraud", "Hypothecation"], answer: 1, explanation: "Usury laws prohibit charging above legal interest rate limits." },
    { question: "A mortgage clause that protects the borrower by requiring lender to release lien upon repayment is the:", options: ["Defeasance clause", "Acceleration clause", "Alienation clause", "Subordination clause"], answer: 0, explanation: "The defeasance clause cancels the lien when the loan is repaid." },
    { question: "What type of loan covers more than one parcel of real estate?", options: ["Package mortgage", "Blanket mortgage", "Participation loan", "Purchase money mortgage"], answer: 1, explanation: "A blanket mortgage secures more than one parcel." },
    { question: "A package mortgage includes financing for:", options: ["Land only", "Land and personal property", "Construction costs only", "Two or more parcels"], answer: 1, explanation: "Package mortgages finance both real estate and personal property." },
    { question: "The right of the borrower to redeem property after foreclosure sale is called:", options: ["Equitable redemption", "Statutory redemption", "Deficiency judgment", "Lis pendens"], answer: 1, explanation: "Florida recognizes statutory redemption after foreclosure in certain cases." },
    { question: "An adjustable-rate mortgage (ARM) changes based on:", options: ["Borrower’s credit score", "Chosen payment plan", "A financial index plus margin", "County property tax rates"], answer: 2, explanation: "ARM rates are tied to an index plus the lender’s margin." },
    { question: "The difference between the interest rate and APR is that APR:", options: ["Always equals the note rate", "Includes finance charges and fees", "Excludes lender costs", "Applies only to FHA loans"], answer: 1, explanation: "APR includes interest plus lender fees and charges." },
    { question: "Which federal law requires disclosure of loan costs using a Loan Estimate?", options: ["RESPA", "Truth in Lending Act (TILA)", "ECOA", "Dodd-Frank Act"], answer: 1, explanation: "TILA requires disclosure of loan costs with standardized forms." },
    { question: "Which law prohibits kickbacks and referral fees in settlement services?", options: ["ECOA", "RESPA", "TILA", "Fair Housing Act"], answer: 1, explanation: "RESPA prohibits unearned fees and referral kickbacks." },
    { question: "The process of pledging property as security without giving up possession is called:", options: ["Hypothecation", "Subordination", "Novation", "Alienation"], answer: 0, explanation: "Hypothecation = using property as collateral without surrendering possession." },
    { question: "The document that itemizes all closing costs for buyer and seller is the:", options: ["Loan Estimate", "HUD-1 Settlement Statement", "Closing Disclosure", "Promissory Note"], answer: 2, explanation: "The Closing Disclosure replaces the old HUD-1 for most residential closings." },
    { question: "The party responsible for preparing the Closing Disclosure is:", options: ["Seller’s attorney", "Buyer’s agent", "Lender", "Listing broker"], answer: 2, explanation: "The lender must prepare and deliver the Closing Disclosure." },
    { question: "Which expense is typically a debit to the seller at closing?", options: ["Sales price", "Loan balance payoff", "Earnest money deposit", "Buyer’s loan origination fee"], answer: 1, explanation: "Seller’s loan payoff is a debit (reduces proceeds)." },
    { question: "The day of closing is usually charged to the:", options: ["Seller", "Buyer", "Title company", "Broker"], answer: 1, explanation: "By custom, the buyer owns the property the day of closing." },
    { question: "Prorations at closing are used to fairly divide:", options: ["Purchase price", "Broker commission", "Property taxes and rents", "Loan origination fees"], answer: 2, explanation: "Prorations allocate items like taxes, rent, and association dues." },
    { question: "Which of the following is usually paid by the buyer at closing?", options: ["Broker’s commission", "Recording of the deed", "Satisfaction of mortgage", "Owner’s title insurance"], answer: 1, explanation: "Buyer generally pays recording fees for the deed." },
    { question: "A debit on the closing statement means:", options: ["Money to be received", "A credit to the other party", "Money to be paid", "Earnest money returned"], answer: 2, explanation: "Debits = amounts the party owes. Credits = amounts received." },
    { question: "The purpose of title insurance is to protect against:", options: ["Future zoning changes", "Defects in title", "Eminent domain", "Future property tax increases"], answer: 1, explanation: "Title insurance covers defects in title not discovered during the search." },
    { question: "The buyer’s earnest money deposit appears on the closing statement as:", options: ["A debit to buyer", "A credit to buyer", "A debit to seller", "Both buyer and seller credit"], answer: 1, explanation: "Earnest money reduces the buyer’s cash needed at closing." },
    { question: "Documentary stamp taxes on the deed are based on:", options: ["Loan amount", "Purchase price", "Assessed value", "Appraised value"], answer: 1, explanation: "Florida documentary stamps on deeds are calculated on the purchase price." },
    { question: "Documentary stamp taxes on the note are based on:", options: ["Loan amount", "Purchase price", "Assessed value", "NOI"], answer: 0, explanation: "Stamps on the promissory note are calculated on the loan amount." },
    { question: "The intangible tax in Florida is charged on:", options: ["Sale price", "Loan amount", "Earnest money", "Title insurance"], answer: 1, explanation: "Intangible tax applies to new mortgages (loan amount)." },
    { question: "If property taxes for the year are $4,380 and closing occurs on June 30, what is the buyer’s prorated share? (Seller pays day of closing)", options: ["$2,190", "$1,095", "$3,285", "$4,380"], answer: 0, explanation: "$4,380 / 365 days = $12/day. Seller pays for 181 days (Jan 1 - June 30). $12 * 181 = $2172. This is a debit to seller, credit to buyer. The closest answer is $2190." },
    { question: "A seller’s title insurance policy is called:", options: ["Owner’s policy", "Mortgagee’s policy", "Hazard policy", "Trustee’s policy"], answer: 0, explanation: "Owner’s title insurance protects the buyer; mortgagee’s protects the lender." },
    { question: "Which closing expense is usually paid by the seller?", options: ["Loan origination fee", "Title search", "Real estate commission", "Recording the mortgage"], answer: 2, explanation: "Seller pays broker’s commission unless negotiated otherwise." },
    { question: "A mortgagee’s title insurance policy protects:", options: ["The buyer", "The lender", "The seller", "The title company"], answer: 1, explanation: "Lender (mortgagee) receives title protection to the loan balance." },
    { question: "If an item is prepaid by the seller, it will appear on the buyer’s closing statement as a:", options: ["Debit", "Credit", "Proration", "Escrow"], answer: 0, explanation: "Prepaid items must be reimbursed to the seller, so they are a debit to the buyer." },
    { question: "If an item is unpaid and owed by the seller, it appears on the seller’s closing statement as a:", options: ["Debit", "Credit", "Escrow holdback", "Proration"], answer: 0, explanation: "Seller owes = debit; buyer owes = debit; opposite side receives credit." },
    { question: "Which of the following is the broker’s responsibility at closing?", options: ["Review closing disclosure for accuracy", "Pay documentary stamp taxes", "Conduct title search", "Disburse loan proceeds"], answer: 0, explanation: "Brokers review closing documents to ensure accuracy and protect clients." },
    { question: "Which party delivers the deed at closing?", options: ["Buyer", "Seller", "Broker", "Lender"], answer: 1, explanation: "The seller delivers the deed; the buyer delivers consideration (money)." }
