<script is:inline>
    // Initialize Stats and Timer immediately
    function initApp() {
        // 1. Calculate Total Questions from the bank
        const banks = window.questionBanks || {}; 
        let total = 0;
        for (let key in banks) {
            total += banks[key].length;
        }
        const totalEl = document.getElementById('total-questions-header');
        if (totalEl) totalEl.innerText = total;

        // 2. Start the Global Timer
        let seconds = 0;
        setInterval(() => {
            seconds++;
            const mins = Math.floor(seconds / 60).toString().padStart(2, '0');
            const secs = (seconds % 60).toString().padStart(2, '0');
            const timerEl = document.getElementById('timer');
            if (timerEl) timerEl.innerText = `${mins}:${secs}`;
        }, 1000);
    }

    // This data object should follow next
